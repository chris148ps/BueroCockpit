<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BueroCockpit.Converters"
        x:Class="BueroCockpit.MainWindow"
        x:CompileBindings="False"
        Width="1280"
        Height="780"
        MinWidth="820"
        MinHeight="600"
        WindowStartupLocation="Manual"
        WindowState="Normal"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="/Assets/BueroCockpit.ico"
        Title="BüroCockpit">
  <Window.Resources>
    <converters:ThumbnailImageConverter x:Key="ThumbnailImageConverter" />
    <converters:DeskThumbnailImageConverter x:Key="DeskThumbnailImageConverter" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,14,0,8" />
    </Style>
    <Style Selector="TextBox, ComboBox, DatePicker, NumericUpDown">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#1F2937" />
      <Setter Property="CaretBrush" Value="#1F2937" />
      <Setter Property="SelectionBrush" Value="#55D9B35C" />
      <Setter Property="SelectionForegroundBrush" Value="#1F2937" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus-within">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus-visible">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="#1F2937" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:focus-within">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ ScrollViewer#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskItemNameEditor">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
    </Style>
    <Style Selector="Button:focus-visible">
      <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button.Primary">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.Primary:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryHoverBorderBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.Danger">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Button.Danger:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonDangerHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button.Danger:focus-visible">
      <Setter Property="Background" Value="{DynamicResource ButtonDangerHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button.PreviewClose">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="Button.DeskZoomButton">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.DeskZoomButton TextBlock">
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,-1,0,0" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                       VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList Border.TaskCard">
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="ListBox#TaskList Border.TaskCard:pointerover">
      <Setter Property="BorderBrush" Value="#000000" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2,8,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                       VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:pointerover:not(:selected) Border.CategoryItemFrame">
      <Setter Property="BorderBrush" Value="#000000" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected Border.CategoryItemFrame">
      <Setter Property="BorderBrush" Value="#000000" />
      <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected:pointerover Border.CategoryItemFrame">
      <Setter Property="BorderBrush" Value="#000000" />
      <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="300,430,*">
    <Border Grid.Column="0"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="0,0,1,0"
            Padding="18">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
          <TextBlock Text="BüroCockpit" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="Lokale Aufgaben" Foreground="{DynamicResource TextSecondaryBrush}" Margin="1,3,0,0" />
        </StackPanel>

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
          <TextBlock Grid.Column="0"
                     Text="Kategorien"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center" />
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="4">
            <Button Width="26"
                    Height="26"
                    MinWidth="26"
                    MinHeight="26"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    ToolTip.Tip="Ausgewählte Kategorie nach oben"
                    Click="MoveCategoryUp_OnClick">
              <TextBlock Text="↑"
                         FontSize="13"
                         LineHeight="13"
                         TextAlignment="Center"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,-1,0,0" />
            </Button>
            <Button Width="26"
                    Height="26"
                    MinWidth="26"
                    MinHeight="26"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    ToolTip.Tip="Ausgewählte Kategorie nach unten"
                    Click="MoveCategoryDown_OnClick">
              <TextBlock Text="↓"
                         FontSize="13"
                         LineHeight="13"
                         TextAlignment="Center"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,-1,0,0" />
            </Button>
          </StackPanel>
        </Grid>

        <ListBox x:Name="CategoryList"
                 HorizontalAlignment="Stretch"
                 ItemsSource="{Binding Categories}"
                 SelectedItem="{Binding SelectedCategory}"
                 SelectionChanged="CategoryList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="CategoryItemFrame"
                      HorizontalAlignment="Stretch"
                      CornerRadius="9"
                      Padding="10,9"
                      Background="{DynamicResource SurfaceElevatedBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Umbenennen" Click="CategoryRenameFromMenu_OnClick" />
                    <MenuItem Header="Löschen" Click="CategoryDeleteFromMenu_OnClick" />
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="*,Auto" MinWidth="200">
                  <TextBlock Text="{Binding Name}"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="8" Padding="7,2">
                    <TextBlock Text="{Binding TaskCount}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="2"
            Padding="26"
            Background="{DynamicResource WindowBackgroundBrush}"
            IsVisible="{Binding IsOverviewSelected}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Übersicht" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding DashboardDateText}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="18">
            <Border Classes="Card"
                    Width="365"
                    MinHeight="230">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding DashboardThisWeekSection.Title}" FontSize="16" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="10" Padding="9,3">
                    <TextBlock Text="{Binding DashboardThisWeekSection.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding DashboardThisWeekSection.EmptyText}"
                           IsVisible="{Binding DashboardThisWeekSection.HasNoTasks}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,10,0,0" />

                <ItemsControl ItemsSource="{Binding DashboardThisWeekSection.Tasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              BorderBrush="{DynamicResource BorderBrushDark}"
                              BorderThickness="1"
                              CornerRadius="10"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DueDateText, StringFormat='Termin: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="Card"
                    Width="365"
                    MinHeight="230">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding DashboardNextWeekSection.Title}" FontSize="16" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="10" Padding="9,3">
                    <TextBlock Text="{Binding DashboardNextWeekSection.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding DashboardNextWeekSection.EmptyText}"
                           IsVisible="{Binding DashboardNextWeekSection.HasNoTasks}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,10,0,0" />

                <ItemsControl ItemsSource="{Binding DashboardNextWeekSection.Tasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              BorderBrush="{DynamicResource BorderBrushDark}"
                              BorderThickness="1"
                              CornerRadius="10"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DueDateText, StringFormat='Termin: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="Card"
                    Width="365"
                    MinHeight="230"
                    Padding="18">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Wiedervorlagen" FontSize="18" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="10" Padding="9,3">
                    <TextBlock Text="{Binding FollowUpTaskCount}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding FollowUpTasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{Binding ReminderCardBackground}"
                              BorderBrush="{Binding ReminderCardBorderBrush}"
                              BorderThickness="1"
                              CornerRadius="10"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding FollowUpDateText, StringFormat='Wiedervorlage: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="2"
            Padding="26"
            Background="{DynamicResource WindowBackgroundBrush}"
            IsVisible="{Binding IsDeskSelected}">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="Schreibtisch" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Freie Fläche für Notizzettel und spätere Schreibtisch-Elemente."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding DeskStatus}"
                       IsVisible="{Binding HasDeskStatus}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Notizzettel hinzufügen"
                    Classes="Primary"
                    Click="AddDeskNote_OnClick"
                    VerticalAlignment="Top" />
            <WrapPanel HorizontalAlignment="Right" ItemSpacing="6" LineSpacing="6">
              <Button Classes="DeskZoomButton"
                      Width="34"
                      MinWidth="34"
                      Click="DeskZoomOut_OnClick">
                <TextBlock Text="−" FontSize="16" LineHeight="16" />
              </Button>
              <Button Classes="DeskZoomButton"
                      Content="{Binding DeskZoomLabel}"
                      MinWidth="72"
                      Padding="10,0"
                      Click="DeskZoomReset_OnClick" />
              <Button Classes="DeskZoomButton"
                      Width="34"
                      MinWidth="34"
                      Click="DeskZoomIn_OnClick">
                <TextBlock Text="+" FontSize="16" LineHeight="16" />
              </Button>
              <Button Classes="DeskZoomButton"
                      Content="Alles anzeigen"
                      MinWidth="108"
                      Padding="10,0"
                      Click="DeskFitToView_OnClick" />
            </WrapPanel>
          </StackPanel>
        </Grid>

        <Border Background="#FBF6E7"
                BorderBrush="#E7D8A8"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20">
          <ScrollViewer x:Name="DeskScrollViewer"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
            <LayoutTransformControl x:Name="DeskZoomHost"
                                    LayoutTransform="{Binding DeskZoomTransform}"
                                    UseRenderTransform="True">
                <Grid x:Name="DeskSurface"
                      Width="{Binding DeskSurfaceWidth}"
                      Height="{Binding DeskSurfaceHeight}"
                      Background="Transparent"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragOver="DeskSurface_OnDragOver"
                      DragDrop.Drop="DeskSurface_OnDrop"
                      PointerPressed="DeskSurface_OnPointerPressed"
                      PointerMoved="DeskSurface_OnPointerMoved"
                      PointerReleased="DeskSurface_OnPointerReleased"
                      PointerCaptureLost="DeskSurface_OnPointerCaptureLost">
                <ItemsControl ItemsSource="{Binding DeskItems}">
                  <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{Binding X}" />
                      <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Background="{Binding NoteBackground}"
                                BorderBrush="{Binding NoteBorderBrush}"
                                BorderThickness="1.2"
                                CornerRadius="18"
                                Tag="DeskNoteRoot"
                                ClipToBounds="True"
                                IsVisible="{Binding IsNoteCard}">
                          <Border.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Zur Detailansicht"
                                        IsEnabled="{Binding HasLinkedTask}"
                                        Click="OpenDeskItemDetailView_OnClick" />
                              <MenuItem Header="Umbenennen"
                                        Click="BeginDeskItemRename_OnClick" />
                              <MenuItem Header="Löschen"
                                        Click="DeleteDeskItem_OnClick" />
                            </ContextMenu>
                          </Border.ContextMenu>
                          <Grid>
                            <Grid RowDefinitions="Auto,*,Auto">
                              <Border Grid.Row="0"
                                      Background="{Binding NoteHeaderBackground}"
                                      CornerRadius="18,18,10,10"
                                      Padding="12,10"
                                      PointerPressed="DeskNoteHeader_OnPointerPressed"
                                      PointerMoved="DeskNoteHeader_OnPointerMoved"
                                      PointerReleased="DeskNoteHeader_OnPointerReleased"
                                      PointerCaptureLost="DeskNoteHeader_OnPointerCaptureLost">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                  <Grid>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               IsVisible="{Binding IsDisplayNameVisible}"
                                               IsHitTestVisible="False" />
                                    <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Classes="DeskNoteEditor DeskItemNameEditor"
                                             IsVisible="{Binding IsRenaming}"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             Background="{Binding NoteHeaderBackground}"
                                             Foreground="#1F2937"
                                             FontWeight="SemiBold"
                                             FontSize="14"
                                             LostFocus="DeskItemNameEditor_OnLostFocus"
                                             KeyDown="DeskItemNameEditor_OnKeyDown" />
                                  </Grid>
                                  <TextBlock Grid.Column="1"
                                             Text="Ziehen"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             FontSize="12" />
                                </Grid>
                              </Border>

                              <TextBox Grid.Row="1"
                                       Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Classes="DeskNoteEditor"
                                       Background="Transparent"
                                       Foreground="#1F2937"
                                       CaretBrush="#1F2937"
                                       SelectionBrush="#55D9B35C"
                                       SelectionForegroundBrush="#1F2937"
                                       BorderThickness="0"
                                       Padding="12,10"
                                       AcceptsReturn="True"
                                       TextWrapping="Wrap"
                                       VerticalContentAlignment="Top"
                                       FontSize="14"
                                       PlaceholderText="Notiztext eingeben">
                                <TextBox.ContextMenu>
                                  <ContextMenu>
                                    <MenuItem Header="Zur Detailansicht"
                                              IsEnabled="{Binding HasLinkedTask}"
                                              Click="OpenDeskItemDetailView_OnClick" />
                                    <MenuItem Header="Umbenennen"
                                              Click="BeginDeskItemRename_OnClick" />
                                    <MenuItem Header="Löschen"
                                              Click="DeleteDeskItem_OnClick" />
                                  </ContextMenu>
                                </TextBox.ContextMenu>
                              </TextBox>

                              <Border Grid.Row="2"
                                      Background="Transparent"
                                      Padding="12,0,12,10">
                                <CheckBox Content="Wichtig"
                                          IsChecked="{Binding IsImportant, Mode=TwoWay}"
                                          HorizontalAlignment="Left" />
                              </Border>
                            </Grid>

                            <Border Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    PointerPressed="DeskResizeGrip_OnPointerPressed"
                                    PointerMoved="DeskResizeGrip_OnPointerMoved"
                                    PointerReleased="DeskResizeGrip_OnPointerReleased"
                                    PointerCaptureLost="DeskResizeGrip_OnPointerCaptureLost"
                                    DoubleTapped="DeskResizeGrip_OnDoubleTapped">
                              <TextBlock Text="↘"
                                         FontSize="10"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False" />
                            </Border>
                          </Grid>
                        </Border>

                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Background="{Binding FileCardBackground}"
                                BorderBrush="{Binding FileCardBorderBrush}"
                                BorderThickness="1.2"
                                CornerRadius="18"
                                Tag="DeskFileRoot"
                                ClipToBounds="False"
                                IsVisible="{Binding IsFileCard}"
                                PointerPressed="DeskNoteHeader_OnPointerPressed"
                                PointerMoved="DeskNoteHeader_OnPointerMoved"
                                PointerReleased="DeskNoteHeader_OnPointerReleased"
                                PointerCaptureLost="DeskNoteHeader_OnPointerCaptureLost"
                                DoubleTapped="DeskFileCard_OnDoubleTapped">
                          <Border.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Zur Detailansicht"
                                        IsEnabled="{Binding HasLinkedTask}"
                                        Click="OpenDeskItemDetailView_OnClick" />
                              <MenuItem Header="Extern öffnen"
                                        Click="OpenDeskFileExternal_OnClick" />
                              <MenuItem Header="Datei neu zuordnen"
                                        Click="ReassignDeskFile_OnClick" />
                              <MenuItem Header="Umbenennen"
                                        Click="BeginDeskItemRename_OnClick" />
                              <MenuItem Header="Löschen"
                                        Click="DeleteDeskItem_OnClick" />
                              <MenuItem Header="{Binding ImportantToggleText}"
                                        Click="ToggleDeskItemImportant_OnClick" />
                            </ContextMenu>
                          </Border.ContextMenu>

                          <Grid>
                            <Grid RowDefinitions="*,Auto"
                                  Margin="0">
                              <Border Grid.Row="0"
                                      Margin="0,0,0,8"
                                      Background="{Binding FileCardPreviewBackground}"
                                      BorderBrush="{Binding FileCardBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      ClipToBounds="True"
                                      IsHitTestVisible="False">
                                <Grid Margin="12">
                                  <Border HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Background="#B42318"
                                          BorderBrush="#7A271A"
                                          BorderThickness="1"
                                          CornerRadius="0,12,0,12"
                                          Padding="9,5"
                                          IsVisible="{Binding IsImportant}">
                                    <TextBlock Text="Wichtig"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFF" />
                                  </Border>

                                  <Image IsVisible="{Binding HasPreviewThumbnail}"
                                         Source="{Binding ThumbnailPath, Converter={StaticResource DeskThumbnailImageConverter}}"
                                         Stretch="Uniform"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         IsHitTestVisible="False"
                                         RenderOptions.BitmapInterpolationMode="MediumQuality" />

                                  <TextBlock IsVisible="{Binding HasPreviewText}"
                                             Text="{Binding PreviewText}"
                                             FontSize="11"
                                             TextWrapping="Wrap"
                                             TextAlignment="Left"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             IsHitTestVisible="False" />

                                  <StackPanel IsVisible="{Binding HasSimplePreviewPlaceholder}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Spacing="10"
                                              IsHitTestVisible="False">
                                    <Border Background="{Binding FileCardBadgeBackground}"
                                            BorderBrush="{Binding FileCardBadgeBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16,12">
                                      <TextBlock Text="{Binding FileKindLabel}"
                                                 FontSize="28"
                                                 FontWeight="SemiBold"
                                                 HorizontalAlignment="Center"
                                                 Foreground="#050505" />
                                    </Border>
                                    <TextBlock Text="{Binding FileBadgeText}"
                                               HorizontalAlignment="Center"
                                               Foreground="#111111"
                                               FontSize="12" />
                                  </StackPanel>
                                </Grid>
                              </Border>

                              <Grid Grid.Row="1"
                                    Margin="2,0,2,0">
                                <TextBlock Text="{Binding FileDisplayName}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#050505"
                                           IsHitTestVisible="False" />
                                <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Classes="DeskNoteEditor DeskItemNameEditor"
                                         IsVisible="{Binding IsRenaming}"
                                         HorizontalAlignment="Stretch"
                                         Background="{DynamicResource WindowBackgroundBrush}"
                                         TextAlignment="Center"
                                         FontSize="12"
                                         LostFocus="DeskItemNameEditor_OnLostFocus"
                                         KeyDown="DeskItemNameEditor_OnKeyDown" />
                              </Grid>
                            </Grid>

                            <Border Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,-2,-2"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    PointerPressed="DeskResizeGrip_OnPointerPressed"
                                    PointerMoved="DeskResizeGrip_OnPointerMoved"
                                    PointerReleased="DeskResizeGrip_OnPointerReleased"
                                    PointerCaptureLost="DeskResizeGrip_OnPointerCaptureLost"
                                    DoubleTapped="DeskResizeGrip_OnDoubleTapped">
                              <TextBlock Text="↘"
                                         FontSize="10"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False" />
                            </Border>
                          </Grid>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </LayoutTransformControl>
          </ScrollViewer>
        </Border>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="2"
            Padding="26"
            Background="{DynamicResource WindowBackgroundBrush}"
            IsVisible="{Binding IsSettingsSelected}">
      <ScrollViewer>
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Einstellungen" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Datenspeicher und lokale Sicherungen" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0" />
          </StackPanel>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Darstellung" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="Erscheinungsbild" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
              <ComboBox ItemsSource="{Binding AppearanceModeOptions}"
                        SelectedItem="{Binding AppearanceMode, Mode=TwoWay}"
                        Width="180" />
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Kategorie-Vorgaben" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,0" />
            <TextBlock Text="Hier werden neue Kategorien angelegt. Umbenennen und Löschen erfolgt per Rechtsklick auf eine Kategorie in der linken Liste."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,8" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding CategoryEditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       TextChanged="CategoryEditor_OnTextChanged"
                       PlaceholderText="Neue Kategorie" />
              <Button Grid.Column="1"
                      Content="Hinzufügen"
                      Click="AddCategory_OnClick" />
            </Grid>

            <TextBlock Text="{Binding CategoryMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0" />

            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Monteur-Vorgaben" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="Diese Namen stehen im Aufgaben-Detailfeld „Monteur“ als Auswahl zur Verfügung."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,8" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding NewTechnicianName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Monteurname" />
              <Button Grid.Column="1"
                      Content="Hinzufügen"
                      Click="AddTechnician_OnClick" />
            </Grid>

            <ItemsControl ItemsSource="{Binding TechnicianOptions}" Margin="0,8,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="InlineCard" Margin="0,0,-2,-2" Padding="10" MinWidth="220" MaxWidth="280">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding}"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" />
                      <Button Grid.Column="1"
                              Content="Entfernen"
                              Classes="Secondary"
                              Click="RemoveTechnician_OnClick" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Gemeinsamer Büro-Datenordner" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="Hier werden Aufgaben, Anhänge und Backups gespeichert. Für mehrere Arbeitsplätze wähle denselben freigegebenen OneDrive-Ordner aus."
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />

              <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="OneDrive-Datenordner auswählen"
                        Click="MigrateStorageLocation_OnClick"
                        Classes="Primary"
                        Margin="0,0,-2,-2" />
                <Button Content="Aktuellen Ordner öffnen"
                        Click="OpenDataFolder_OnClick"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,-2,-2" />
                <Button Content="Dateien in gemeinsamen Datenordner übernehmen"
                        Click="CheckLegacyFilePaths_OnClick"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,0,-2" />
              </WrapPanel>

              <TextBlock Text="{Binding FilePathCheckStatus}"
                         IsVisible="{Binding HasFilePathCheckStatus}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="2" Margin="0,4,0,0">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Aktuell verwendet"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding AppDataDirectory}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Standard"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding DefaultAppDataDirectory}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </Grid>

              <StackPanel Spacing="4" Margin="0,4,0,0">
                <TextBlock Text="Technische Details"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                  <TextBlock Grid.Row="0"
                             Grid.Column="0"
                             Text="Datenbank"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12" />
                  <TextBlock Grid.Row="0"
                             Grid.Column="1"
                             Text="{Binding DatabasePath}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1"
                             Grid.Column="0"
                             Text="Aufgaben-/Anhangsordner"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12" />
                  <TextBlock Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding TasksDirectory}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2"
                             Grid.Column="0"
                             Text="Backup-Ordner"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12" />
                  <TextBlock Grid.Row="2"
                             Grid.Column="1"
                             Text="{Binding BackupDirectory}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3"
                             Grid.Column="0"
                             Text="Lock-Datei"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12" />
                  <TextBlock Grid.Row="3"
                             Grid.Column="1"
                             Text="{Binding LockPath}"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </Grid>
                <TextBlock Text="BüroCockpit ist nicht für gleichzeitiges Bearbeiten derselben Daten von mehreren PCs ausgelegt. Bitte immer nur auf einem Gerät gleichzeitig öffnen."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
              </StackPanel>

              <TextBlock Text="{Binding AppInstanceLockStatus}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding StorageLocationStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
              <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Backup-Ordner öffnen"
                        Click="OpenBackupFolder_OnClick"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,-2,-2" />
                <Button Content="Standard-Datenordner öffnen"
                        Click="OpenDefaultDataFolder_OnClick"
                        FontSize="12"
                        Padding="10,6"
                        Margin="0,0,0,8" />
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="OneDrive / iPad-Bearbeitung" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="OneDrive-Bearbeitungsordner" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
              <TextBlock Text="{Binding OneDriveEditDirectory}"
                         IsVisible="{Binding HasOneDriveEditDirectory}"
                         TextWrapping="Wrap" />
              <TextBlock Text="Noch kein OneDrive-Bearbeitungsordner gewählt."
                         IsVisible="{Binding HasNoOneDriveEditDirectory}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                <Button Content="OneDrive-Ordner auswählen" Click="SelectOneDriveFolder_OnClick" />
                <Button Grid.Column="1" Content="OneDrive-Ordner öffnen" Click="OpenOneDriveFolder_OnClick" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Backup" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Backup jetzt erstellen" Classes="Primary" Click="CreateBackup_OnClick" />
              </Grid>
              <TextBlock Text="{Binding BackupStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding LastBackupTime, StringFormat='Letztes Backup: {0}'}"
                         IsVisible="{Binding HasLastBackup}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding LastBackupPath}"
                         IsVisible="{Binding HasLastBackup}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
              <TextBlock Text="Verfügbare Backups"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="Noch keine Backups vorhanden. Mit „Backup jetzt erstellen“ legen Sie das erste Sicherheitsbackup an."
                         IsVisible="{Binding HasNoBackupEntries}"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasBackupEntries}">
                <ItemsControl ItemsSource="{Binding BackupEntries}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1"
                              CornerRadius="10"
                              Padding="10"
                              Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding TimestampText}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FileName}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding HintText}"
                                       IsVisible="{Binding HasHintText}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Spacing="6"
                                      HorizontalAlignment="Right">
                            <TextBlock Text="{Binding SizeText}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Right" />
                            <Button Content="Backup wiederherstellen"
                                    Click="RestoreBackup_OnClick"
                                    HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="18">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Aktuelle Version" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentAppVersion}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Update-Kanal" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UpdateSource}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Auto-Update-Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AutoUpdateInstallStatus}" TextWrapping="Wrap" />
              </Grid>
              <TextBlock Text="Lokaler Feed-Ordner oder Feed-URL" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBox Grid.Row="3" Text="{Binding UpdateFeedUrl}"
                         TextChanged="UpdateFeed_OnTextChanged"
                         PlaceholderText="z. B. publish/local-update-test/feed" />
                <Button Grid.Row="3" Grid.Column="1" Content="Speichern" Click="SaveUpdateFeed_OnClick" />
              </Grid>
              <TextBlock Text="{Binding UpdateStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                <Button Content="Nach Updates suchen" Click="CheckUpdates_OnClick" />
                <Button Grid.Column="1"
                        Content="Update installieren"
                        Classes="Primary"
                        IsEnabled="{Binding IsUpdateAvailable}"
                        Click="InstallUpdate_OnClick" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1" Padding="20" Background="{DynamicResource WindowBackgroundBrush}" IsVisible="{Binding IsTaskAreaVisible}">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,14">
          <StackPanel>
            <TextBlock Text="{Binding SelectedCategory.Name}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TaskListCaption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
            <TextBox Text="{Binding SearchText}"
                     TextChanged="SearchBox_OnTextChanged"
                     PlaceholderText="Suchen nach Kunde, Titel, Adresse, Monteur, Status, Material, Anhang"
                     Margin="0,12,0,0" />
            <CheckBox IsChecked="{Binding IsGlobalSearchEnabled}"
                      Content="Alle Bereiche durchsuchen"
                      Margin="0,8,0,0" />

            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        Margin="0,8,0,0">
              <TextBlock Text="Sortierung:"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding SortModeOptions}"
                        SelectedItem="{Binding SelectedCategory.SortMode, Mode=TwoWay}"
                        SelectionChanged="CategorySortMode_OnSelectionChanged"
                        Width="135"
                        MinHeight="28"
                        FontSize="12" />
            </StackPanel>
            <Border Classes="Card"
                    Margin="0,10,0,0"
                    Padding="12"
                    IsVisible="{Binding IsTaskUndoPanelVisible}">
              <StackPanel Spacing="6">
                <Button Content="{Binding UndoTaskChangeText}"
                        ToolTip.Tip="{Binding UndoTaskChangeToolTip}"
                        Click="UndoTaskChange_OnClick"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{Binding TaskUndoMessage}"
                           IsVisible="{Binding HasTaskUndoMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="Card"
                    IsVisible="{Binding IsTrashSelected}"
                    Margin="0,10,0,0"
                    Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Papierkorb"
                           FontWeight="SemiBold"
                           FontSize="14" />
                <TextBlock Text="Gelöschte Aufgaben bleiben hier, bis sie wiederhergestellt oder endgültig entfernt werden."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <Button Content="Papierkorb leeren"
                        Classes="Danger"
                        Click="EmptyTrash_OnClick"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding HasTrashItems}" />
              </StackPanel>
            </Border>
          </StackPanel>
          <Button Grid.Column="1"
                  Classes="Primary"
                  Content="Neue Aufgabe"
                  Click="NewTask_OnClick"
                  VerticalAlignment="Top" />
        </Grid>

        <Border DockPanel.Dock="Top"
                Classes="Card"
                Padding="12"
                Margin="0,0,0,14"
                IsVisible="{Binding IsGlobalSearchPanelVisible}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding GlobalSearchCaption}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" />
            <ItemsControl ItemsSource="{Binding GlobalSearchResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource AccentSoftBrush}"
                          BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="10"
                          Padding="10"
                          Margin="0,0,0,8"
                          PointerPressed="GlobalSearchResult_OnPointerPressed">
                    <StackPanel Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="8" Padding="8,2">
                          <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                      </Grid>
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                      <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                    IsVisible="{Binding HasCategoryNameChips}"
                                    Margin="0,0,8,0">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{DynamicResource AccentSoftBrush}"
                                    BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="6,2"
                                    Margin="0,0,4,4">
                              <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding MatchInfo}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Classes="Card"
                Padding="12"
                Margin="0,0,0,14"
                IsVisible="{Binding IsTrashEmpty}">
          <StackPanel Spacing="4">
            <TextBlock Text="Papierkorb ist leer."
                       FontWeight="SemiBold"
                       FontSize="14" />
            <TextBlock Text="Gelöschte Aufgaben werden hier angezeigt, bis sie wiederhergestellt oder endgültig entfernt werden."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <ListBox x:Name="TaskList"
                 ItemsSource="{Binding VisibleTasks}"
                 SelectedItem="{Binding SelectedTask}"
                 SelectionChanged="TaskList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="Card TaskCard"
                      Margin="0,0,0,10"
                      Background="{DynamicResource SurfaceBackgroundBrush}"
                      BorderBrush="{Binding CardBorderBrush}"
                      BorderThickness="1"
                      PointerEntered="TaskCard_OnPointerEntered"
                      PointerExited="TaskCard_OnPointerExited">
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="15" />
                  <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                  <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                IsVisible="{Binding ShowCategoryHint}"
                                Margin="0,2,12,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="6,2"
                                Margin="0,0,4,4"
                                MaxWidth="130">
                          <TextBlock Text="{Binding}"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Technician, StringFormat='Monteur: {0}'}"
                             IsVisible="{Binding HasTechnician}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding CustomerAddress, StringFormat='Adresse: {0}'}"
                             IsVisible="{Binding HasCustomerAddress}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             MaxHeight="48" />
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Termin" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Row="1" Text="{Binding Status}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DueDateText}" />
                  </Grid>
                  <TextBlock Text="{Binding SentAtText, StringFormat='Gesendet: {0}'}"
                             IsVisible="{Binding HasSentAt}"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding FollowUpDateText, StringFormat='Wiedervorlage: {0}'}"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="2"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1,0,0,0"
            IsVisible="{Binding IsTaskAreaVisible}">
      <ScrollViewer>
        <StackPanel Margin="24" Spacing="10" IsVisible="{Binding HasSelectedTask}">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
            <TextBlock Text="Details" FontSize="24" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Speichern und prüfen" Classes="Primary" Click="SaveTask_OnClick" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Wiederherstellen" Click="RestoreTask_OnClick" IsVisible="{Binding IsTrashSelected}" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Löschen" Classes="Danger" Click="DeleteTask_OnClick" IsVisible="{Binding IsNotTrashSelected}" />
          </Grid>

          <TextBlock Text="Hinweis: Ähnliche Aufträge werden beim Speichern geprüft."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,-4,0,2" />

          <TextBlock Classes="SectionTitle" Text="Aufgabe" />
          <Border Classes="Card" Padding="14">
            <StackPanel Spacing="8">
              <TextBlock Text="Kunde" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox Text="{Binding SelectedTask.CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Kundenname" GotFocus="TaskDetailEditor_OnGotFocus" />

              <TextBlock Text="Kundenadresse" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.CustomerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Adresse"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="64"
                       GotFocus="TaskDetailEditor_OnGotFocus" />

              <TextBlock Text="Titel" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Kurzer Aufgabentitel" GotFocus="TaskDetailEditor_OnGotFocus" />

              <TextBlock Text="Beschreibung / Notiz" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Notizen, Verlauf, offene Punkte"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="110"
                       GotFocus="TaskDetailEditor_OnGotFocus" />
            </StackPanel>
          </Border>

          <TextBlock Classes="SectionTitle" Text="Organisation" Margin="0,8,0,0" />
          <Border Classes="Card" Padding="12">
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="Monteur" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Row="0" Grid.Column="2" Text="Gesendet am" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Grid.Row="0" Grid.Column="3" Text="Material bestellt am" Foreground="{DynamicResource TextSecondaryBrush}" />

              <ComboBox Grid.Row="1" Grid.Column="0"
                        ItemsSource="{Binding StatusOptions}"
                        SelectedItem="{Binding SelectedTask.Status}"
                        GotFocus="TaskDetailEditor_OnGotFocus"
                        SelectionChanged="StatusCombo_OnSelectionChanged" />

              <ComboBox Grid.Row="1"
                        Grid.Column="1"
                        ItemsSource="{Binding TechnicianOptions}"
                        SelectedItem="{Binding SelectedTask.Technician, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        GotFocus="TaskDetailEditor_OnGotFocus"
                        SelectionChanged="TechnicianCombo_OnSelectionChanged" />

              <TextBox Grid.Row="1"
                       Grid.Column="2"
                       Text="{Binding SentAtInputText}"
                       Tag="SentAt"
                       PlaceholderText="TT.MM.JJJJ"
                       GotFocus="TaskDetailEditor_OnGotFocus"
                       LostFocus="SentAtTextBox_OnLostFocus"
                       TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />

              <TextBox Grid.Row="1"
                       Grid.Column="3"
                       Text="{Binding MaterialOrderedAtInputText}"
                       Tag="MaterialOrderedAt"
                       PlaceholderText="TT.MM.JJJJ"
                       GotFocus="TaskDetailEditor_OnGotFocus"
                       LostFocus="MaterialOrderedAtTextBox_OnLostFocus"
                       TextChanged="DateTextBox_OnTextChanged"
                       KeyDown="DateTextBox_OnKeyDown" />
            </Grid>
          </Border>

          <Border Classes="Card"
                  Padding="12"
                  IsVisible="{Binding SelectedTask.HasCategoryNameChips}">
            <StackPanel Spacing="8">
              <TextBlock Text="Zugeordnete Kategorien"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <ItemsControl ItemsSource="{Binding SelectedTask.CategoryNameChips}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="6,2"
                            Margin="0,0,4,4">
                      <TextBlock Text="{Binding}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <TextBlock Classes="SectionTitle" Text="Kategorien" Margin="0,12,0,0" />
          <Border Classes="Card" Padding="12">
            <ItemsControl ItemsSource="{Binding TaskCategorySelections}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox Content="{Binding Name}"
                            IsChecked="{Binding IsSelected}"
                            Margin="0,0,16,8"
                            Click="TaskCategoryCheckBox_OnChanged" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <TextBlock Classes="SectionTitle" Text="Termine" Margin="0,12,0,0" />
          <Border Classes="Card" Padding="14">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                <TextBlock Text="Termin" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Wiedervorlage" Foreground="{DynamicResource TextSecondaryBrush}" />
                <StackPanel Grid.Row="1" Spacing="6">
                  <TextBox Text="{Binding DueDateInputText}"
                           Tag="DueDate"
                           PlaceholderText="TT.MM.JJJJ"
                           GotFocus="TaskDetailEditor_OnGotFocus"
                           LostFocus="DueDateTextBox_OnLostFocus"
                           TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                  <TextBox Text="{Binding FollowUpDateInputText}"
                           Tag="FollowUpDate"
                           PlaceholderText="TT.MM.JJJJ"
                           GotFocus="TaskDetailEditor_OnGotFocus"
                           LostFocus="FollowUpDateTextBox_OnLostFocus"
                           TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />
                </StackPanel>
              </Grid>
              <TextBlock Text="{Binding DateInputMessage}"
                         IsVisible="{Binding HasDateInputMessage}"
                         Foreground="{DynamicResource DangerBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Classes="SectionTitle" Text="Material" Margin="0" />
            <Button Grid.Column="1" Content="+ Material hinzufügen" Click="AddMaterial_OnClick" />
          </Grid>
          <TextBlock Text="Materialpositionen für diesen Auftrag."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,-4,0,2" />

          <Border Classes="Card"
                  IsVisible="{Binding HasNoMaterials}"
                  Padding="12"
                  Margin="0,0,0,8">
            <TextBlock Text="Noch kein Material erfasst." Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>

          <ItemsControl ItemsSource="{Binding Materials}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="Card" Margin="0,0,0,8" Padding="12">
                  <Grid ColumnDefinitions="120,78,*,132,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Text="Menge" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Einheit" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="2" Text="Bezeichnung" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="3" Text="Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <NumericUpDown Grid.Row="1" Value="{Binding Quantity}" Minimum="0" Increment="1" Width="112" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Unit}" />
                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Name}" PlaceholderText="Material" />
                    <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding $parent[Window].DataContext.MaterialStatusOptions}" SelectedItem="{Binding Status}" />
                    <Button Grid.Row="1" Grid.Column="4" Content="×" Click="DeleteMaterial_OnClick" Tag="{Binding}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

              <Border Classes="Card"
                  IsVisible="{Binding HasSelectedAttachment}"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="SectionTitle" Text="Vorschau" Margin="0" VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="PreviewClose"
                        Click="ClosePreview_OnClick">
                  <TextBlock Text="×"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             TextAlignment="Center"
                             FontSize="14"
                             Margin="0,-1,0,0" />
                </Button>
              </Grid>

                      <Border MinHeight="220"
                      MaxHeight="520"
                      CornerRadius="12"
                      Background="{DynamicResource InputBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      ClipToBounds="True">
                <Grid>
                  <Image IsVisible="{Binding HasPreviewImage}"
                         Source="{Binding PreviewImagePath, Converter={StaticResource ThumbnailImageConverter}}"
                         Stretch="Uniform"
                         MaxWidth="420"
                         MaxHeight="520"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                  <TextBlock IsVisible="{Binding HasPreviewPlaceholder}"
                             Text="{Binding SelectedAttachment.FileTypeBadge}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="28"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
              </Border>

	              <StackPanel Spacing="0">
	                <TextBlock Text="{Binding AttachmentPreviewTitle}" FontWeight="SemiBold" TextWrapping="Wrap" />
	                <TextBlock Text="{Binding AttachmentPreviewInfo}"
	                           Foreground="{DynamicResource TextSecondaryBrush}"
	                           FontSize="12"
	                           Margin="0,3,0,0"
	                           TextWrapping="Wrap" />
	              </StackPanel>

              <Border Background="{DynamicResource InputBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="iPad-Bearbeitung"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="Beim Übernehmen wird diese Anlage aktualisiert. Die alte Version wird gesichert."
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Content="Für iPad bereitstellen"
                            Click="ExportAttachmentForIpad_OnClick"
                            Margin="0,0,-2,-2" />
                    <Button Content="Änderungen prüfen"
                            Click="CheckIpadChanges_OnClick"
                            Margin="0,0,-2,-2" />
                    <Button Content="Bearbeitung übernehmen"
                            Classes="Primary"
                            IsVisible="{Binding CanImportAttachmentEdit}"
                            Click="ImportIpadChanges_OnClick"
                            Margin="0,0,0,8" />
                  </WrapPanel>
                  <TextBlock Text="{Binding AttachmentEditStatus}"
                             IsVisible="{Binding HasAttachmentEditStatus}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Classes="SectionTitle" Text="Anhänge" Margin="0" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Content="Ausgewählte drucken" Click="PrintSelectedAttachments_OnClick" />
              <Button Content="Datei anhängen" Click="AddAttachment_OnClick" />
            </StackPanel>
          </Grid>
          <TextBlock Text="Dateien, Fotos und PDFs zum Auftrag."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,-4,0,2" />

          <Border Classes="Card"
                  Padding="14"
                  Margin="0,0,0,10"
                  Background="{DynamicResource InputBackgroundBrush}"
                  BorderBrush="{DynamicResource BorderBrushDark}"
                  DragDrop.AllowDrop="True"
                  DragDrop.DragOver="AttachmentDropZone_OnDragOver"
                  DragDrop.Drop="AttachmentDropZone_OnDrop">
            <TextBlock Text="Dateien hier ablegen oder über „Datei anhängen“ auswählen"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </Border>

          <ItemsControl ItemsSource="{Binding Attachments}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="Card"
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="{DynamicResource SurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        PointerPressed="AttachmentCard_OnPointerPressed">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Extern öffnen"
                                Click="OpenAttachmentExternal_OnClick" />
                      <MenuItem Header="Datei neu zuordnen"
                                Click="ReassignAttachmentFile_OnClick" />
                      <MenuItem Header="Entfernen"
                                Click="DeleteAttachment_OnClick"
                                Tag="{Binding}" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="170,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="160" Height="110" CornerRadius="10" Background="{DynamicResource InputBackgroundBrush}" ClipToBounds="True">
                      <Grid>
                        <Image IsVisible="{Binding HasThumbnail}"
                               Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailImageConverter}}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <TextBlock IsVisible="{Binding HasNoThumbnail}"
                                   Text="{Binding FileTypeBadge}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding FileDisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#111827" />
                      <TextBlock Text="{Binding FileTypeBadge}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                      <TextBlock Text="{Binding FileStatusText}"
                                 IsVisible="{Binding HasMissingFile}"
                                 Foreground="{DynamicResource DangerBrush}"
                                 FontSize="12"
                                 Margin="0,4,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
	                    <StackPanel Grid.Column="2" Spacing="8">
	                      <Button Content="Extern öffnen"
	                              Click="OpenAttachmentExternalFromList_OnClick" />
	                      <Button Content="Auf Schreibtisch legen"
	                              Click="PlaceAttachmentOnDesk_OnClick" />
	                      <Button Content="Entfernen" Click="DeleteAttachment_OnClick" Tag="{Binding}" />
	                      <CheckBox IsChecked="{Binding IsSelectedForPrint, Mode=TwoWay}"
	                                Content="Auswählen"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
