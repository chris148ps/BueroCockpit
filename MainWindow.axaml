<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BueroCockpit.Converters"
        x:Class="BueroCockpit.MainWindow"
        x:CompileBindings="False"
        Width="1280"
        Height="780"
        MinWidth="820"
        MinHeight="600"
        WindowStartupLocation="Manual"
        WindowState="Normal"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="/Assets/BueroCockpit.ico"
        Title="BüroCockpit">
  <Window.Resources>
    <converters:ThumbnailImageConverter x:Key="ThumbnailImageConverter" />
    <converters:DeskThumbnailImageConverter x:Key="DeskThumbnailImageConverter" />
    <DataTemplate x:Key="DashboardTaskTemplate">
      <Border Classes="InlineCard"
              Margin="0,0,0,8"
              PointerPressed="DashboardTask_OnPointerPressed">
        <Border.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Wiedervorlage bestätigen"
                      IsVisible="{Binding HasFollowUpDate}"
                      Click="ConfirmFollowUp_OnClick" />
          </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DueDateOverviewText, StringFormat='Termin: {0}'}"
                     IsVisible="{Binding HasDueDate}"
                     Classes="OverviewCardSubtitle" />
          <TextBlock Text="{Binding FollowUpDateText, StringFormat='Wiedervorlage: {0}'}"
                     IsVisible="{Binding HasFollowUpDate}"
                     Classes="OverviewCardSubtitle" />
          <TextBlock Text="{Binding Technician, StringFormat='Monteur: {0}'}"
                     IsVisible="{Binding HasTechnician}"
                     Classes="OverviewCardSubtitle" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,14,0,8" />
    </Style>
    <Style Selector="TextBlock.TaskDetailSectionTitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="Margin" Value="0,4,0,0" />
    </Style>
    <Style Selector="TextBlock.TaskDetailFieldLabel">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.TaskDetailSubtitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Border.TaskDetailCard">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.TaskDetailInset">
      <Setter Property="Background" Value="{DynamicResource ContentSecondaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Border.TaskDetailHeader">
      <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.TaskDetailChip">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Border.OverviewCard">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLarge}" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.OverviewSubCard">
      <Setter Property="Background" Value="{DynamicResource ContentSecondaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="TextBlock.OverviewCardTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.OverviewCardSubtitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.OverviewEmpty">
      <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,8,0,0" />
    </Style>
    <Style Selector="TextBox, ComboBox, DatePicker, NumericUpDown">
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="TextBox:pointerover, ComboBox:pointerover, DatePicker:pointerover, NumericUpDown:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
    </Style>
    <Style Selector="TextBox:focus-within, ComboBox:focus-within, DatePicker:focus-within, NumericUpDown:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBox:disabled, ComboBox:disabled, DatePicker:disabled, NumericUpDown:disabled">
      <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource DeskInkBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource DeskInkBrush}" />
      <Setter Property="SelectionBrush" Value="{DynamicResource DeskSelectionBrush}" />
      <Setter Property="SelectionForegroundBrush" Value="{DynamicResource DeskInkBrush}" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus-within">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:focus-visible">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource DeskInkBrush}" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ Border#PART_BorderElement:focus-within">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.DeskNoteEditor /template/ ScrollViewer#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.DeskItemNameEditor">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="Padding" Value="{DynamicResource ControlPadding}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource ContentSecondaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
    </Style>
    <Style Selector="Button:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Opacity" Value="0.75" />
    </Style>
    <Style Selector="Button.Primary">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
    </Style>
    <Style Selector="Button.Primary:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonPrimaryHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
    </Style>
    <Style Selector="Button.Secondary">
      <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
    </Style>
    <Style Selector="Button.Secondary:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
    </Style>
    <Style Selector="Button.Tertiary">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.Icon">
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="Button.SettingsSectionHeader">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.SettingsSectionHeader:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.SettingsTab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.SettingsTab:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.SettingsTab.Selected">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TechnicianDelete">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
      <Setter Property="FontSize" Value="21" />
    </Style>
    <Style Selector="Button.TechnicianDelete:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerHoverBackgroundBrush}" />
    </Style>
    <Style Selector="Button.TechnicianDelete:focus-visible">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.SettingsSectionToggle">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.Danger">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Button.Danger:pointerover">
      <Setter Property="Background" Value="{DynamicResource ButtonDangerHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button.Danger:focus-visible">
      <Setter Property="Background" Value="{DynamicResource ButtonDangerHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerHoverBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ButtonDangerHoverForegroundBrush}" />
    </Style>
    <Style Selector="Button.PreviewClose">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="Button.DeskZoomButton">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.DeskZoomButton TextBlock">
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,-1,0,0" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                       VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2,8,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                       VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:pointerover:not(:selected) Border.CategoryItemFrame">
      <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected Border.CategoryItemFrame">
      <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected:pointerover Border.CategoryItemFrame">
      <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.CategoryExpandGlyph">
      <Setter Property="Width" Value="10" />
      <Setter Property="MinWidth" Value="10" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.CategoryExpandGlyph:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Border.CategoryDropLine">
      <Setter Property="Height" Value="2" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.CategoryDropInside">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLarge}" />
      <Setter Property="Padding" Value="{DynamicResource CardPadding}" />
    </Style>
    <Style Selector="TextBlock.TaskTableHeader">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="ListBox#TaskList Border.TaskCard">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover:not(:selected) Border.TaskCard">
      <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected Border.TaskCard">
      <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected:pointerover Border.TaskCard">
      <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.InlineCard">
      <Setter Property="Background" Value="{DynamicResource ContentSecondaryBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMedium}" />
    </Style>
    <Style Selector="Border.FollowUpCard.HasFollowUps">
      <Setter Property="Background" Value="{DynamicResource DangerBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.FollowUpCount">
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
    </Style>
    <Style Selector="TextBlock.FollowUpCountText">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="Border.FollowUpCard.HasFollowUps TextBlock.FollowUpCardTitle">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Border.FollowUpCard.HasFollowUps Border.FollowUpCount">
      <Setter Property="Background" Value="{DynamicResource DangerBackgroundBrush}" />
    </Style>
    <Style Selector="Border.FollowUpCard.HasFollowUps Border.InlineCard">
      <Setter Property="Background" Value="{DynamicResource DangerBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Border.FollowUpCard.HasFollowUps TextBlock.FollowUpCountText">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="ContextMenu">
      <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLarge}" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
    </Style>
    <Style Selector="ToolTip">
      <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSmall}" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
  </Window.Styles>

  <Grid x:Name="RootLayoutGrid"
        ColumnDefinitions="280,*,6,380"
        PointerReleased="RootLayoutGrid_OnPointerReleased">
    <Border Grid.Column="0"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="0,0,1,0"
            Padding="18"
            AutomationProperties.LandmarkType="Navigation">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,20" Margin="0,0,0,18">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="BüroCockpit" FontSize="24" FontWeight="SemiBold" />
              <TextBlock Text="{Binding CurrentAppVersion, StringFormat=v{0}}"
                         FontSize="11"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,4" />
            </StackPanel>
            <TextBlock Text="Lokale Aufgaben" Foreground="{DynamicResource TextSecondaryBrush}" Margin="1,3,0,0" />
          </StackPanel>
          <Grid Grid.Column="1"
                Width="20"
                Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                IsVisible="{Binding HasIpadSnapshotStatus}"
                ToolTip.Tip="{Binding IpadSnapshotStatus}">
            <TextBlock Text="↻"
                       FontSize="18"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsIpadSnapshotExportRunning}" />
            <TextBlock Text="✓"
                       FontSize="17"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasSuccessfulIpadSnapshotStatus}" />
            <TextBlock Text="⚠"
                       FontSize="16"
                       Foreground="{DynamicResource DangerBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasFailedIpadSnapshotStatus}" />
          </Grid>
        </Grid>

        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*"
              Margin="0,0,0,8"
              Background="{Binding CategoryRootDropBackground}"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="CategoryRootDropZone_OnDragOver"
              DragDrop.DragLeave="CategoryDropZone_OnDragLeave"
              DragDrop.Drop="CategoryRootDropZone_OnDrop">
          <Border BorderBrush="{Binding CategoryRootDropBorderBrush}"
                  BorderThickness="0,0,0,2"
                  Padding="0,0,0,4">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="Kategorien"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="als Hauptkategorie"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         IsVisible="{Binding IsCategoryRootDropTarget}"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>

        <ListBox x:Name="CategoryList"
                 HorizontalAlignment="Stretch"
                 AutomationProperties.Name="Hauptnavigation und Kategorien"
                 AutomationProperties.AutomationId="CategoryNavigationList"
                 DragDrop.AllowDrop="True"
                 DragDrop.DragOver="CategoryRootDropZone_OnDragOver"
                 DragDrop.Drop="CategoryRootDropZone_OnDrop"
                 ItemsSource="{Binding SidebarCategories}"
                 SelectedItem="{Binding SelectedCategory}"
                 SelectionChanged="CategoryList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="CategoryItemFrame"
                      HorizontalAlignment="Stretch"
                      CornerRadius="{DynamicResource CornerRadiusLarge}"
                      Padding="10,9"
                      Background="{DynamicResource SurfaceBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragOver="CategorySettingsItem_OnDragOver"
                      DragDrop.DragLeave="CategoryDropZone_OnDragLeave"
                      DragDrop.Drop="CategorySettingsItem_OnDrop"
                      PointerPressed="CategorySettingsItem_OnPointerPressed"
                      PointerMoved="CategorySettingsItem_OnPointerMoved"
                      DoubleTapped="CategoryItemFrame_OnDoubleTapped">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Umbenennen" Click="CategoryRenameFromMenu_OnClick" />
                    <MenuItem Header="Löschen" Click="CategoryDeleteFromMenu_OnClick" />
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid MinWidth="200">
                  <Border Classes="CategoryDropLine"
                          Margin="{Binding DropLineMargin}"
                          VerticalAlignment="Top"
                          IsVisible="{Binding IsDropBefore}" />
                  <Border Classes="CategoryDropLine"
                          Margin="{Binding DropLineMargin}"
                          VerticalAlignment="Bottom"
                          IsVisible="{Binding IsDropAfter}" />
                  <Border Classes="CategoryDropInside"
                          IsVisible="{Binding IsDropInside}" />
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                    <Border Width="{Binding SidebarIndent}" />
                    <TextBlock Grid.Column="1"
                               Classes="CategoryExpandGlyph"
                               Text="{Binding ExpandGlyph}"
                               Cursor="Hand"
                               PointerPressed="ToggleCategoryExpanded_OnPointerPressed" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="3" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="{DynamicResource CornerRadiusMedium}" Padding="7,2">
                      <TextBlock Text="{Binding TaskCount}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Border>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="3"
            Padding="26"
            Background="{DynamicResource ContentBackgroundBrush}"
            IsVisible="{Binding IsOverviewSelected}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Übersicht" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Heute" Classes="OverviewCardTitle" Margin="0,6,0,0" />
            <TextBlock Text="{Binding DashboardTodayText}" Classes="OverviewCardSubtitle" Margin="0,2,0,0" />
          </StackPanel>

          <Border Classes="Card OverviewCard">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Text="Termine" Classes="OverviewCardTitle" />
                  <TextBlock Text="Heute, diese Woche und nächste Woche"
                             Classes="OverviewCardSubtitle" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding DashboardTodaySection.Count, StringFormat='Heute: {0}'}"
                           Classes="OverviewCardSubtitle"
                           VerticalAlignment="Center" />
              </Grid>
              <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Classes="OverviewSubCard">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding DashboardTodaySection.Title}" Classes="OverviewCardTitle" />
                      <TextBlock Grid.Column="1" Text="{Binding DashboardTodaySection.Count}" Classes="OverviewCardSubtitle" />
                    </Grid>
                    <TextBlock Text="{Binding DashboardTodaySection.EmptyText}"
                               IsVisible="{Binding DashboardTodaySection.HasNoTasks}"
                               Classes="OverviewEmpty" />
                    <ItemsControl ItemsSource="{Binding DashboardTodaySection.Tasks}"
                                  ItemTemplate="{StaticResource DashboardTaskTemplate}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="OverviewSubCard">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding DashboardThisWeekSection.Title}" Classes="OverviewCardTitle" />
                      <TextBlock Grid.Column="1" Text="{Binding DashboardThisWeekSection.Count}" Classes="OverviewCardSubtitle" />
                    </Grid>
                    <TextBlock Text="{Binding DashboardThisWeekSection.EmptyText}"
                               IsVisible="{Binding DashboardThisWeekSection.HasNoTasks}"
                               Classes="OverviewEmpty" />
                    <ItemsControl ItemsSource="{Binding DashboardThisWeekSection.Tasks}"
                                  ItemTemplate="{StaticResource DashboardTaskTemplate}" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="OverviewSubCard">
                  <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding DashboardNextWeekSection.Title}" Classes="OverviewCardTitle" />
                      <TextBlock Grid.Column="1" Text="{Binding DashboardNextWeekSection.Count}" Classes="OverviewCardSubtitle" />
                    </Grid>
                    <TextBlock Text="{Binding DashboardNextWeekSection.EmptyText}"
                               IsVisible="{Binding DashboardNextWeekSection.HasNoTasks}"
                               Classes="OverviewEmpty" />
                    <ItemsControl ItemsSource="{Binding DashboardNextWeekSection.Tasks}"
                                  ItemTemplate="{StaticResource DashboardTaskTemplate}" />
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
            <Border Classes="Card OverviewCard FollowUpCard"
                    Classes.HasFollowUps="{Binding HasFollowUpTasks}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="OverviewCardTitle FollowUpCardTitle" Text="Wiedervorlagen" />
                  <Border Classes="FollowUpCount" Grid.Column="1" CornerRadius="{DynamicResource CornerRadiusMedium}" Padding="8,3">
                    <TextBlock Classes="FollowUpCountText" Text="{Binding FollowUpTaskCount}" FontWeight="SemiBold" />
                  </Border>
                </Grid>
                <TextBlock Text="Keine Wiedervorlagen."
                           IsVisible="{Binding HasNoFollowUpTasks}"
                           Classes="OverviewEmpty" />
                <ItemsControl ItemsSource="{Binding FollowUpTasks}"
                              ItemTemplate="{StaticResource DashboardTaskTemplate}" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="Card OverviewCard">
              <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Text="Mobile Eingänge" Classes="OverviewCardTitle" />
                  <TextBlock Text="Neue Aufträge, Fotos und Skizzen"
                             Classes="OverviewCardSubtitle" />
                </StackPanel>
                <TextBlock Text="Keine neuen mobilen Eingänge."
                           IsVisible="{Binding HasNoNewMobileInboxData}"
                           Classes="OverviewEmpty" />
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8" IsVisible="{Binding HasNewMobileInboxData}">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Neue Aufträge" />
                    <TextBlock Grid.Column="1" Text="{Binding NewMobileInboxTaskCount}" Classes="OverviewCardSubtitle" />
                  </Grid>
                  <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                    <TextBlock Text="Neue Fotos" />
                    <TextBlock Grid.Column="1" Text="{Binding NewMobilePhotoCount}" Classes="OverviewCardSubtitle" />
                  </Grid>
                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                    <TextBlock Text="Neue Skizzen" />
                    <TextBlock Grid.Column="1" Text="{Binding NewMobileSketchCount}" Classes="OverviewCardSubtitle" />
                  </Grid>
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Column="2" Classes="Card OverviewCard">
              <StackPanel Spacing="10">
                <TextBlock Text="Synchronisation" Classes="OverviewCardTitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8">
                  <TextBlock Text="Desktop" Classes="OverviewCardSubtitle" />
                  <TextBlock Grid.Column="1" Text="{Binding DesktopConnectionStatusText}" />
                  <TextBlock Grid.Row="1" Text="Netzwerk-Sync" Classes="OverviewCardSubtitle" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NetworkSyncStatusText}" />
                </Grid>
                <StackPanel Spacing="2">
                  <TextBlock Text="Letzte erfolgreiche Synchronisation" Classes="OverviewCardSubtitle" />
                  <TextBlock Text="{Binding LastSuccessfulSynchronizationText}" Classes="OverviewCardSubtitle" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Spacing="2">
                  <TextBlock Text="Verbundenes Gerät" Classes="OverviewCardSubtitle" />
                  <TextBlock Text="{Binding ConnectedDeviceText}" TextWrapping="Wrap" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="18" IsVisible="False">
            <Border Classes="Card"
                    Width="365"
                    MinHeight="230">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding DashboardThisWeekSection.Title}" FontSize="16" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="{DynamicResource CornerRadiusMedium}" Padding="9,3">
                    <TextBlock Text="{Binding DashboardThisWeekSection.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding DashboardThisWeekSection.EmptyText}"
                           IsVisible="{Binding DashboardThisWeekSection.HasNoTasks}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,10,0,0" />

                <ItemsControl ItemsSource="{Binding DashboardThisWeekSection.Tasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              BorderBrush="{DynamicResource BorderBrushDark}"
                              BorderThickness="1"
                              CornerRadius="{DynamicResource CornerRadiusLarge}"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Wiedervorlage bestätigen"
                                      IsVisible="{Binding HasFollowUpDate}"
                                      Click="ConfirmFollowUp_OnClick" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock Text="{Binding Technician, StringFormat='Monteur: {0}'}"
                                     IsVisible="{Binding HasTechnician}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontSize="12" />
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DueDateOverviewText, StringFormat='Termin: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="Card"
                    Width="365"
                    MinHeight="230">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding DashboardNextWeekSection.Title}" FontSize="16" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="{DynamicResource CornerRadiusMedium}" Padding="9,3">
                    <TextBlock Text="{Binding DashboardNextWeekSection.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </Border>
                </Grid>

                <TextBlock Text="{Binding DashboardNextWeekSection.EmptyText}"
                           IsVisible="{Binding DashboardNextWeekSection.HasNoTasks}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,10,0,0" />

                <ItemsControl ItemsSource="{Binding DashboardNextWeekSection.Tasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceElevatedBrush}"
                              BorderBrush="{DynamicResource BorderBrushDark}"
                              BorderThickness="1"
                              CornerRadius="{DynamicResource CornerRadiusLarge}"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Wiedervorlage bestätigen"
                                      IsVisible="{Binding HasFollowUpDate}"
                                      Click="ConfirmFollowUp_OnClick" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock Text="{Binding Technician, StringFormat='Monteur: {0}'}"
                                     IsVisible="{Binding HasTechnician}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontSize="12" />
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DueDateOverviewText, StringFormat='Termin: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="Card FollowUpCard"
                    Classes.HasFollowUps="{Binding HasFollowUpTasks}"
                    Width="365"
                    MinHeight="230"
                    Padding="18">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="FollowUpCardTitle" Text="Wiedervorlagen" FontSize="18" FontWeight="SemiBold" />
                  <Border Classes="FollowUpCount" Grid.Column="1" CornerRadius="{DynamicResource CornerRadiusMedium}" Padding="9,3">
                    <TextBlock Classes="FollowUpCountText" Text="{Binding FollowUpTaskCount}" FontWeight="SemiBold" />
                  </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding FollowUpTasks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource DangerBackgroundBrush}"
                              BorderBrush="{DynamicResource DangerBrush}"
                              BorderThickness="1"
                              CornerRadius="{DynamicResource CornerRadiusLarge}"
                              Padding="10"
                              Margin="0,0,0,8"
                              PointerPressed="DashboardTask_OnPointerPressed">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Wiedervorlage bestätigen"
                                      IsVisible="{Binding HasFollowUpDate}"
                                      Click="ConfirmFollowUp_OnClick" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel Spacing="5">
                          <TextBlock Text="{Binding CustomerName}"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     TextWrapping="Wrap" />
                          <TextBlock Text="{Binding Title}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     TextWrapping="Wrap" />
                          <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                        IsVisible="{Binding ShowCategoryHint}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Padding="6,2"
                                        Margin="0,0,4,4">
                                  <TextBlock Text="{Binding}"
                                             FontSize="11"
                                             Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding FollowUpDateText, StringFormat='Wiedervorlage: {0}'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                          </Grid>
                          <TextBlock Text="{Binding DueDateCompactText, StringFormat='Termin: {0}'}"
                                     IsVisible="{Binding HasDueDate}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontSize="12" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="3"
            Padding="26"
            Background="{DynamicResource ContentBackgroundBrush}"
            IsVisible="{Binding IsDeskSelected}">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="Schreibtisch" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Freie Fläche für Notizzettel und spätere Schreibtisch-Elemente."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding DeskStatus}"
                       IsVisible="{Binding HasDeskStatus}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Notizzettel hinzufügen"
                    Classes="Primary"
                    Click="AddDeskNote_OnClick"
                    VerticalAlignment="Top" />
            <WrapPanel HorizontalAlignment="Right" ItemSpacing="6" LineSpacing="6">
              <Button Classes="DeskZoomButton"
                      Width="34"
                      MinWidth="34"
                      Click="DeskZoomOut_OnClick">
                <TextBlock Text="−" FontSize="16" LineHeight="16" />
              </Button>
              <Button Classes="DeskZoomButton"
                      Content="{Binding DeskZoomLabel}"
                      MinWidth="72"
                      Padding="10,0"
                      Click="DeskZoomReset_OnClick" />
              <Button Classes="DeskZoomButton"
                      Width="34"
                      MinWidth="34"
                      Click="DeskZoomIn_OnClick">
                <TextBlock Text="+" FontSize="16" LineHeight="16" />
              </Button>
              <Button Classes="DeskZoomButton"
                      Content="Alles anzeigen"
                      MinWidth="108"
                      Padding="10,0"
                      Click="DeskFitToView_OnClick" />
            </WrapPanel>
          </StackPanel>
        </Grid>

        <Border Background="{DynamicResource ContentSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="{DynamicResource CornerRadiusLarge}"
                Padding="{DynamicResource DialogPadding}">
          <ScrollViewer x:Name="DeskScrollViewer"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
            <LayoutTransformControl x:Name="DeskZoomHost"
                                    LayoutTransform="{Binding DeskZoomTransform}"
                                    UseRenderTransform="True">
                <Grid x:Name="DeskSurface"
                      Width="{Binding DeskSurfaceWidth}"
                      Height="{Binding DeskSurfaceHeight}"
                      Background="Transparent"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragOver="DeskSurface_OnDragOver"
                      DragDrop.Drop="DeskSurface_OnDrop"
                      PointerPressed="DeskSurface_OnPointerPressed"
                      PointerMoved="DeskSurface_OnPointerMoved"
                      PointerReleased="DeskSurface_OnPointerReleased"
                      PointerCaptureLost="DeskSurface_OnPointerCaptureLost">
                <ItemsControl ItemsSource="{Binding DeskItems}">
                  <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                      <Setter Property="Canvas.Left" Value="{Binding X}" />
                      <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                  </ItemsControl.Styles>
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <Canvas />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Background="{Binding NoteBackground}"
                                BorderBrush="{Binding NoteBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadiusLarge}"
                                Tag="DeskNoteRoot"
                                ClipToBounds="True"
                                IsVisible="{Binding IsNoteCard}">
                          <Border.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Zur Detailansicht"
                                        IsEnabled="{Binding HasLinkedTask}"
                                        Click="OpenDeskItemDetailView_OnClick" />
                              <MenuItem Header="Umbenennen"
                                        Click="BeginDeskItemRename_OnClick" />
                              <MenuItem Header="Löschen"
                                        Click="DeleteDeskItem_OnClick" />
                            </ContextMenu>
                          </Border.ContextMenu>
                          <Grid>
                            <Grid RowDefinitions="Auto,*,Auto">
                              <Border Grid.Row="0"
                                      Background="{Binding NoteHeaderBackground}"
                                      CornerRadius="8,8,6,6"
                                      Padding="12,10"
                                      PointerPressed="DeskNoteHeader_OnPointerPressed"
                                      PointerMoved="DeskNoteHeader_OnPointerMoved"
                                      PointerReleased="DeskNoteHeader_OnPointerReleased"
                                      PointerCaptureLost="DeskNoteHeader_OnPointerCaptureLost">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                  <Grid>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource DeskStrongInkBrush}"
                                               IsVisible="{Binding IsDisplayNameVisible}"
                                               IsHitTestVisible="False" />
                                    <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Classes="DeskNoteEditor DeskItemNameEditor"
                                             IsVisible="{Binding IsRenaming}"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             Background="{Binding NoteHeaderBackground}"
                                             Foreground="{DynamicResource DeskInkBrush}"
                                             FontWeight="SemiBold"
                                             FontSize="14"
                                             LostFocus="DeskItemNameEditor_OnLostFocus"
                                             KeyDown="DeskItemNameEditor_OnKeyDown" />
                                  </Grid>
                                  <TextBlock Grid.Column="1"
                                             Text="Ziehen"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             FontSize="12" />
                                </Grid>
                              </Border>

                              <TextBox Grid.Row="1"
                                       Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Classes="DeskNoteEditor"
                                       Background="Transparent"
                                       Foreground="{DynamicResource DeskInkBrush}"
                                       CaretBrush="{DynamicResource DeskInkBrush}"
                                       SelectionBrush="{DynamicResource DeskSelectionBrush}"
                                       SelectionForegroundBrush="{DynamicResource DeskInkBrush}"
                                       BorderThickness="0"
                                       Padding="12,10"
                                       AcceptsReturn="True"
                                       TextWrapping="Wrap"
                                       VerticalContentAlignment="Top"
                                       FontSize="14"
                                       PlaceholderText="Notiztext eingeben">
                                <TextBox.ContextMenu>
                                  <ContextMenu>
                                    <MenuItem Header="Zur Detailansicht"
                                              IsEnabled="{Binding HasLinkedTask}"
                                              Click="OpenDeskItemDetailView_OnClick" />
                                    <MenuItem Header="Umbenennen"
                                              Click="BeginDeskItemRename_OnClick" />
                                    <MenuItem Header="Löschen"
                                              Click="DeleteDeskItem_OnClick" />
                                  </ContextMenu>
                                </TextBox.ContextMenu>
                              </TextBox>

                              <Border Grid.Row="2"
                                      Background="Transparent"
                                      Padding="12,0,12,10">
                                <CheckBox Content="Wichtig"
                                          IsChecked="{Binding IsImportant, Mode=TwoWay}"
                                          HorizontalAlignment="Left" />
                              </Border>
                            </Grid>

                            <Border Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,0"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    PointerPressed="DeskResizeGrip_OnPointerPressed"
                                    PointerMoved="DeskResizeGrip_OnPointerMoved"
                                    PointerReleased="DeskResizeGrip_OnPointerReleased"
                                    PointerCaptureLost="DeskResizeGrip_OnPointerCaptureLost"
                                    DoubleTapped="DeskResizeGrip_OnDoubleTapped">
                              <TextBlock Text="↘"
                                         FontSize="10"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False" />
                            </Border>
                          </Grid>
                        </Border>

                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Background="{Binding FileCardBackground}"
                                BorderBrush="{Binding FileCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadiusLarge}"
                                Tag="DeskFileRoot"
                                ClipToBounds="False"
                                IsVisible="{Binding IsFileCard}"
                                PointerPressed="DeskNoteHeader_OnPointerPressed"
                                PointerMoved="DeskNoteHeader_OnPointerMoved"
                                PointerReleased="DeskNoteHeader_OnPointerReleased"
                                PointerCaptureLost="DeskNoteHeader_OnPointerCaptureLost"
                                DoubleTapped="DeskFileCard_OnDoubleTapped">
                          <Border.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Zur Detailansicht"
                                        IsEnabled="{Binding HasLinkedTask}"
                                        Click="OpenDeskItemDetailView_OnClick" />
                              <MenuItem Header="Extern öffnen"
                                        Click="OpenDeskFileExternal_OnClick" />
                              <MenuItem Header="Datei neu zuordnen"
                                        Click="ReassignDeskFile_OnClick" />
                              <MenuItem Header="Umbenennen"
                                        Click="BeginDeskItemRename_OnClick" />
                              <MenuItem Header="Löschen"
                                        Click="DeleteDeskItem_OnClick" />
                              <MenuItem Header="{Binding ImportantToggleText}"
                                        Click="ToggleDeskItemImportant_OnClick" />
                            </ContextMenu>
                          </Border.ContextMenu>

                          <Grid>
                            <Grid RowDefinitions="*,Auto"
                                  Margin="0">
                              <Border Grid.Row="0"
                                      Margin="0,0,0,8"
                                      Background="{Binding FileCardPreviewBackground}"
                                      BorderBrush="{Binding FileCardBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      ClipToBounds="True"
                                      IsHitTestVisible="False">
                                <Grid Margin="12">
                                  <Border HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Background="{DynamicResource DangerBackgroundBrush}"
                                          BorderBrush="{DynamicResource DangerBrush}"
                                          BorderThickness="1"
                                          CornerRadius="0,6,0,6"
                                          Padding="9,5"
                                          IsVisible="{Binding IsImportant}">
                                    <TextBlock Text="Wichtig"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource DangerBrush}" />
                                  </Border>

                                  <Image IsVisible="{Binding HasPreviewThumbnail}"
                                         Source="{Binding ThumbnailPath, Converter={StaticResource DeskThumbnailImageConverter}}"
                                         Stretch="Uniform"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         IsHitTestVisible="False"
                                         RenderOptions.BitmapInterpolationMode="MediumQuality" />

                                  <TextBlock IsVisible="{Binding HasPreviewText}"
                                             Text="{Binding PreviewText}"
                                             FontSize="11"
                                             TextWrapping="Wrap"
                                             TextAlignment="Left"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             IsHitTestVisible="False" />

                                  <StackPanel IsVisible="{Binding HasSimplePreviewPlaceholder}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Spacing="10"
                                              IsHitTestVisible="False">
                                    <Border Background="{Binding FileCardBadgeBackground}"
                                            BorderBrush="{Binding FileCardBadgeBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource CornerRadiusLarge}"
                                            Padding="16,12">
                                      <TextBlock Text="{Binding FileKindLabel}"
                                                 FontSize="28"
                                                 FontWeight="SemiBold"
                                                 HorizontalAlignment="Center"
                                                 Foreground="{DynamicResource DeskStrongInkBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding FileBadgeText}"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource DeskStrongInkBrush}"
                                               FontSize="12" />
                                  </StackPanel>
                                </Grid>
                              </Border>

                              <Grid Grid.Row="1"
                                    Margin="2,0,2,0">
                                <TextBlock Text="{Binding FileDisplayName}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DeskStrongInkBrush}"
                                           IsHitTestVisible="False" />
                                <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Classes="DeskNoteEditor DeskItemNameEditor"
                                         IsVisible="{Binding IsRenaming}"
                                         HorizontalAlignment="Stretch"
                                         Background="{DynamicResource ContentBackgroundBrush}"
                                         TextAlignment="Center"
                                         FontSize="12"
                                         LostFocus="DeskItemNameEditor_OnLostFocus"
                                         KeyDown="DeskItemNameEditor_OnKeyDown" />
                              </Grid>
                            </Grid>

                            <Border Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,-2,-2"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    PointerPressed="DeskResizeGrip_OnPointerPressed"
                                    PointerMoved="DeskResizeGrip_OnPointerMoved"
                                    PointerReleased="DeskResizeGrip_OnPointerReleased"
                                    PointerCaptureLost="DeskResizeGrip_OnPointerCaptureLost"
                                    DoubleTapped="DeskResizeGrip_OnDoubleTapped">
                              <TextBlock Text="↘"
                                         FontSize="10"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False" />
                            </Border>
                          </Grid>
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </LayoutTransformControl>
          </ScrollViewer>
        </Border>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="3"
            Padding="26"
            Background="{DynamicResource ContentBackgroundBrush}"
            IsVisible="{Binding IsSettingsSelected}">
      <ScrollViewer>
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Einstellungen" FontSize="22" FontWeight="SemiBold" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,14,0,0">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="SettingsTab" Tag="General" Click="SettingsTab_OnClick" Content="Allgemein" Classes.Selected="{Binding IsSettingsGeneralTabSelected}" />
                <Button Classes="SettingsTab" Tag="Orders" Click="SettingsTab_OnClick" Content="Aufträge" Classes.Selected="{Binding IsSettingsOrdersTabSelected}" />
                <Button Classes="SettingsTab" Tag="Categories" Click="SettingsTab_OnClick" Content="Kategorien" Classes.Selected="{Binding IsSettingsCategoriesTabSelected}" />
                <Button Classes="SettingsTab" Tag="Technicians" Click="SettingsTab_OnClick" Content="Techniker" Classes.Selected="{Binding IsSettingsTechniciansTabSelected}" />
                <Button Classes="SettingsTab" Tag="Display" Click="SettingsTab_OnClick" Content="Darstellung" Classes.Selected="{Binding IsSettingsDisplayTabSelected}" />
                <Button Classes="SettingsTab" Tag="DataSync" Click="SettingsTab_OnClick" Content="Daten &amp; Pfade" Classes.Selected="{Binding IsSettingsDataTabSelected}" />
                <Button Classes="SettingsTab" Tag="LocalNetworkSync" Click="SettingsTab_OnClick" Content="Sync" Classes.Selected="{Binding IsSettingsSyncTabSelected}" />
              </StackPanel>
            </ScrollViewer>
          </StackPanel>

          <Border Classes="Card" IsVisible="{Binding IsSettingsGeneralOrDisplayTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="General" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Allgemein">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Allgemein" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsGeneralToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="16" IsVisible="{Binding IsSettingsGeneralOpen}">
                <StackPanel Spacing="10">
                  <TextBlock Text="Darstellung" FontSize="15" FontWeight="SemiBold" />
                  <TextBlock Text="Erscheinungsbild" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <ComboBox ItemsSource="{Binding AppearanceModeOptions}"
                            SelectedItem="{Binding AppearanceMode, Mode=TwoWay}"
                            Width="180" />
                </StackPanel>
                <StackPanel Spacing="6">
                  <CheckBox Content="Schreibtisch anzeigen"
                            IsChecked="{Binding ShowDesktopSetting, Mode=TwoWay}"
                            AutomationProperties.Name="Schreibtisch anzeigen"
                            AutomationProperties.AutomationId="ShowDesktopSetting"
                            AutomationProperties.HelpText="Zeigt den optionalen Schreibtisch in der linken Navigation an." />
                  <TextBlock Text="Zeigt den optionalen Schreibtisch für freie Notizen und lose Dateien in der linken Navigation an."
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="{Binding IsSettingsDataTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="DataSync" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Datenordner und Synchronisation">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Datenordner und Synchronisation" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsDataSyncToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="14" IsVisible="{Binding IsSettingsDataSyncOpen}">
                <TextBlock Text="BüroCockpit arbeitet mit lokalen Daten. iPad und Desktop werden künftig ausschließlich über den lokalen Netzwerk-Sync verbunden; aktuell ist noch kein echter Sync aktiv."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Arbeitsordner" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppDataDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Datenordner" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OneDriveEditDirectory}" IsVisible="{Binding HasOneDriveEditDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="Noch kein Datenordner gewählt." IsVisible="{Binding HasNoOneDriveEditDirectory}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="SyncRoot" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IpadSyncRootDirectory}" IsVisible="{Binding HasIpadSyncRootDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="SyncRoot wird aus dem Datenordner abgeleitet." IsVisible="{Binding HasNoIpadSyncRootDirectory}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </Grid>
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                  <Button Content="Datenordner auswählen"
                          Click="MigrateStorageLocation_OnClick"
                          Classes="Primary"
                          Margin="0,0,-2,-2" />
                  <Button Content="Aktuellen Ordner öffnen"
                          Click="OpenDataFolder_OnClick"
                          FontSize="12"
                          Padding="10,6"
                          Margin="0,0,-2,-2" />
                  <Button Content="Dateien in gemeinsamen Datenordner übernehmen"
                          Click="CheckLegacyFilePaths_OnClick"
                          FontSize="12"
                          Padding="10,6"
                          Margin="0,0,0,-2" />
                </WrapPanel>
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10">
                  <Button Content="Datenordner auswählen" Click="SelectOneDriveFolder_OnClick" />
                  <Button Grid.Column="1" Content="Datenordner öffnen" Click="OpenOneDriveFolder_OnClick" />
                </Grid>
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Backup" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Backup jetzt erstellen" Classes="Primary" Click="CreateBackup_OnClick" />
                  </Grid>
                  <TextBlock Text="{Binding BackupStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding LastBackupTime, StringFormat='Letztes Backup: {0}'}" IsVisible="{Binding HasLastBackup}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding LastBackupPath}" IsVisible="{Binding HasLastBackup}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="Verfügbare Backups" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextTertiaryBrush}" />
                  <TextBlock Text="Noch keine Backups vorhanden. Mit „Backup jetzt erstellen“ legen Sie das erste Sicherheitsbackup an." IsVisible="{Binding HasNoBackupEntries}" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasBackupEntries}">
                    <ItemsControl ItemsSource="{Binding BackupEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusLarge}" Padding="10" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding TimestampText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HintText}" IsVisible="{Binding HasHintText}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" HorizontalAlignment="Right" />
                                <Button Content="Backup wiederherstellen" Click="RestoreBackup_OnClick" HorizontalAlignment="Right" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="{Binding IsSettingsSyncTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="LocalNetworkSync" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Lokaler Netzwerk-Sync">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Lokaler Netzwerk-Sync" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsLocalNetworkSyncToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="8" IsVisible="{Binding IsSettingsLocalNetworkSyncOpen}">
                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LocalNetworkSyncStatusText}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Bonjour" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalNetworkSyncBonjourStatusText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Bedienführung" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                    <Run Text="1. BüroCockpit auf diesem Rechner geöffnet lassen." />
                    <LineBreak />
                    <Run Text="2. Lokalen Testdienst manuell starten." />
                    <LineBreak />
                    <Run Text="3. iPad sucht den Desktop per Bonjour, falls verfügbar." />
                    <LineBreak />
                    <Run Text="4. Manuelle IP-Eingabe bleibt der Fallback." />
                    <LineBreak />
                    <Run Text="5. Es werden noch keine Produktivdaten übertragen." />
                  </TextBlock>
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Gespeicherter Gerätename" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LocalNetworkSyncDeviceNameText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Port" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LocalNetworkSyncPortText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Gerätename" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" VerticalAlignment="Center" />
                  <TextBox Grid.Row="5" Grid.Column="1"
                           Text="{Binding LocalNetworkSyncDeviceNameInput}"
                           TextChanged="LocalNetworkSyncDeviceName_OnTextChanged"
                           PlaceholderText="nicht festgelegt" />
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="Port bearbeiten" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" VerticalAlignment="Center" />
                  <TextBox Grid.Row="6" Grid.Column="1"
                           Text="{Binding LocalNetworkSyncPortInput}"
                           TextChanged="LocalNetworkSyncPort_OnTextChanged"
                           PlaceholderText="nicht festgelegt" />
                  <TextBlock Grid.Row="7" Grid.Column="0" Text="Testdienst" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <WrapPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Lokalen Testdienst starten"
                            Margin="0,0,10,8"
                            Click="StartLocalNetworkSyncTestService_OnClick" />
                    <Button Content="Lokalen Testdienst stoppen"
                            Margin="0,0,0,8"
                            Click="StopLocalNetworkSyncTestService_OnClick" />
                  </WrapPanel>
                  <TextBlock Grid.Row="8" Grid.Column="0" Text="Teststatus" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LocalNetworkSyncTestServiceStatus}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="9" Grid.Column="0" Text="LAN-Adresse(n)" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding LocalNetworkSyncTestServiceAddressText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="10" Grid.Column="0" Text="Hinweis" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding LocalNetworkSyncHintText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="11" Grid.Column="0" Text="Vorgemerkte iPads" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <StackPanel Grid.Row="11" Grid.Column="1" Spacing="6">
                    <TextBlock Text="Noch kein echter Sync aktiv." Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="Noch kein iPad vorgemerkt."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasNoLocalNetworkRememberedDevices}" />
                    <ItemsControl ItemsSource="{Binding LocalNetworkRememberedDevices}" IsVisible="{Binding HasLocalNetworkRememberedDevices}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3" ColumnSpacing="12">
                              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DeviceName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Platform}" Foreground="{DynamicResource TextSecondaryBrush}" />
                              <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding LastSeenText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                  <Button Grid.Row="12" Grid.Column="1"
                          Content="Lokal speichern"
                          HorizontalAlignment="Left"
                          Click="SaveLocalNetworkSyncSettings_OnClick" />
                </Grid>
                <TextBlock Text="{Binding LocalNetworkSyncSettingsStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="False">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="Technicians" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Techniker">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Techniker" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsTechniciansToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="10" IsVisible="{Binding IsSettingsTechniciansOpen}">
                <TextBlock Text="Diese Namen stehen im Aufgaben-Detailfeld „Monteur“ als Auswahl zur Verfügung und werden zentral unter Sync/live/settings.json gespeichert."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,8" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0"
                           Text="{Binding TechnicianNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="Monteurname" />
                  <Button Grid.Column="1" Content="Hinzufügen" Click="AddTechnician_OnClick" />
                </Grid>
                <ItemsControl ItemsSource="{Binding TechnicianOptions}" Margin="0,8,0,0">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="InlineCard" Margin="0,0,-2,-2" Padding="10" MinWidth="220" MaxWidth="280">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          <Button Grid.Column="1" Content="×" Classes="Danger" Width="30" Height="30" Padding="0"
                                  FontSize="18" ToolTip.Tip="Techniker entfernen"
                                  AutomationProperties.Name="Techniker entfernen" Click="RemoveTechnician_OnClick" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="16" IsVisible="{Binding IsSettingsTechniciansTabSelected}">
            <Border Grid.Column="0" Classes="Card" Padding="0" MinHeight="470">
              <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="18,16,18,14" Spacing="4">
                  <TextBlock Text="Techniker / Monteure" FontSize="17" FontWeight="SemiBold" />
                  <TextBlock Text="Verwalte deine Techniker und Monteure." Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding TechnicianProfiles}"
                         SelectedItem="{Binding SelectedTechnicianProfile, Mode=TwoWay}"
                         BorderThickness="0" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="18,13" BorderBrush="{DynamicResource BorderBrushDark}" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="15" />
                          <Button Grid.Column="1" Classes="TechnicianDelete" Content="×" ToolTip.Tip="Techniker löschen"
                                  AutomationProperties.Name="Techniker löschen" Click="RemoveTechnician_OnClick" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="2" Content="＋  Techniker hinzufügen" Classes="Secondary" HorizontalAlignment="Left" Margin="18,14" Click="AddTechnician_OnClick" />
              </Grid>
            </Border>
            <Border Grid.Column="1" Classes="Card" MinHeight="470">
              <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="Techniker bearbeiten" FontSize="17" FontWeight="SemiBold" />
                  <TextBlock Text="Daten des ausgewählten Technikers." Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="0,24,0,0" Spacing="14" IsEnabled="{Binding HasSelectedTechnicianProfile}">
                  <StackPanel Spacing="6"><TextBlock Text="Name" Foreground="{DynamicResource TextSecondaryBrush}" /><TextBox Text="{Binding TechnicianNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                  <StackPanel Spacing="6"><TextBlock Text="Kürzel (optional)" Foreground="{DynamicResource TextSecondaryBrush}" /><TextBox Text="{Binding TechnicianAbbreviationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                  <StackPanel Spacing="6"><TextBlock Text="E-Mail (optional)" Foreground="{DynamicResource TextSecondaryBrush}" /><TextBox Text="{Binding TechnicianEmailInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                  <StackPanel Spacing="6"><TextBlock Text="Telefon (optional)" Foreground="{DynamicResource TextSecondaryBrush}" /><TextBox Text="{Binding TechnicianPhoneInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                </StackPanel>
                <Button Grid.Row="2" Content="Speichern" Classes="Primary" HorizontalAlignment="Right" IsEnabled="{Binding HasSelectedTechnicianProfile}" Click="SaveTechnicianProfile_OnClick" />
              </Grid>
            </Border>
          </Grid>

          <Border Classes="Card" IsVisible="{Binding IsSettingsCategoriesTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="Categories" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Kategorien">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Kategorien" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsCategoriesToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="10" IsVisible="{Binding IsSettingsCategoriesOpen}">
                <TextBlock Text="Hier werden Kategorien als Baum angelegt und per Drag &amp; Drop sortiert oder untergeordnet."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,8" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0"
                           Text="{Binding CategoryEditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           TextChanged="CategoryEditor_OnTextChanged"
                           PlaceholderText="Neue Kategorie" />
                  <Button Grid.Column="1" Content="Hinzufügen" Click="AddCategory_OnClick" />
                </Grid>
                <TextBlock Text="{Binding CategoryMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <Border Classes="InlineCard"
                        Margin="0,8,0,0"
                        Padding="10"
                        Background="{Binding CategoryRootDropBackground}"
                        BorderBrush="{Binding CategoryRootDropBorderBrush}"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="CategoryRootDropZone_OnDragOver"
                        DragDrop.DragLeave="CategoryDropZone_OnDragLeave"
                        DragDrop.Drop="CategoryRootDropZone_OnDrop">
                  <TextBlock Text="Hauptkategorien"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </Border>
                <ItemsControl ItemsSource="{Binding CategoryManagementCategories}" Margin="0,8,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="InlineCard"
                              Margin="0,0,0,6"
                              Padding="10"
                              DragDrop.AllowDrop="True"
                              DragDrop.DragOver="CategorySettingsItem_OnDragOver"
                              DragDrop.DragLeave="CategoryDropZone_OnDragLeave"
                              DragDrop.Drop="CategorySettingsItem_OnDrop"
                              PointerPressed="CategorySettingsItem_OnPointerPressed"
                              PointerMoved="CategorySettingsItem_OnPointerMoved">
                        <Grid>
                          <Border Classes="CategoryDropLine"
                                  Margin="{Binding DropLineMargin}"
                                  VerticalAlignment="Top"
                                  IsVisible="{Binding IsDropBefore}" />
                          <Border Classes="CategoryDropLine"
                                  Margin="{Binding DropLineMargin}"
                                  VerticalAlignment="Bottom"
                                  IsVisible="{Binding IsDropAfter}" />
                          <Border Classes="CategoryDropInside"
                                  IsVisible="{Binding IsDropInside}" />
                          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                              <Border Width="{Binding SelectionIndent}" />
                              <TextBlock Text="{Binding SelectionName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Umbenennen" Classes="Secondary" Click="CategoryRenameFromSettings_OnClick" />
                            <Button Grid.Column="2" Content="Entfernen" Classes="Secondary" Click="CategoryRemoveFromSettings_OnClick" />
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="{Binding IsSettingsOrdersTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="Orders" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Aufträge">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Aufträge" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsOrdersToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="10" IsVisible="{Binding IsSettingsOrdersOpen}">
                <TextBlock Text="Auftragsbezogene Sonderbereiche und Verwaltungszugänge."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <Button Content="Archiv öffnen"
                        Classes="Secondary"
                        HorizontalAlignment="Left"
                        IsVisible="{Binding HasArchiveCategory}"
                        Click="OpenArchiveCategory_OnClick" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="{Binding IsSettingsGeneralTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="Updates" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Updates">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Updates" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsUpdatesToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="10" IsVisible="{Binding IsSettingsUpdatesOpen}">
                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Aktuelle Version" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentAppVersion}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Update-Kanal" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UpdateSource}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Auto-Update-Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AutoUpdateInstallStatus}" TextWrapping="Wrap" />
                </Grid>
                <TextBlock Text="Lokaler Feed-Ordner oder Feed-URL" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                  <TextBox Grid.Row="3" Text="{Binding UpdateFeedUrl}"
                           TextChanged="UpdateFeed_OnTextChanged"
                           PlaceholderText="z. B. publish/local-update-test/feed" />
                  <Button Grid.Row="3" Grid.Column="1" Content="Speichern" Click="SaveUpdateFeed_OnClick" />
                </Grid>
                <TextBlock Text="{Binding UpdateStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                  <Button Content="Nach Updates suchen" Click="CheckUpdates_OnClick" />
                  <Button Grid.Column="1"
                          Content="Update installieren"
                          Classes="Primary"
                          IsEnabled="{Binding IsUpdateAvailable}"
                          Click="InstallUpdate_OnClick" />
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="Card" IsVisible="{Binding IsSettingsGeneralTabSelected}">
            <StackPanel Spacing="10">
              <Button Classes="SettingsSectionHeader" Tag="Diagnostics" Click="SettingsSectionHeader_OnClick" AutomationProperties.Name="Diagnose">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Diagnose" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Classes="SettingsSectionToggle" Text="{Binding SettingsDiagnosticsToggleText}" />
                </Grid>
              </Button>
              <StackPanel Spacing="10" IsVisible="{Binding IsSettingsDiagnosticsOpen}">
                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="App-Datenordner" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppDataDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Standard" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DefaultAppDataDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Datenbank" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DatabasePath}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Aufgaben/Anhänge" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TasksDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Backup-Ordner" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding BackupDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Lock-Datei" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LockPath}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="SaveNow-Ziel" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" />
                  <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding IpadSyncRootDirectory}" IsVisible="{Binding HasIpadSyncRootDirectory}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="6" Grid.Column="1" Text="Kein Datenordner gewählt." IsVisible="{Binding HasNoIpadSyncRootDirectory}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </Grid>
                <TextBlock Text="Lokaler Netzwerk-Sync ist vorbereitet. Es gibt aktuell keine stille Hintergrundaktualisierung und keinen echten Produktivdaten-Sync."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding FilePathCheckStatus}" IsVisible="{Binding HasFilePathCheckStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding AppInstanceLockStatus}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding StorageLocationStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding IpadLiveFileLastSuccessfulExport}" IsVisible="{Binding HasIpadLiveFileLastSuccessfulExport}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding IpadLiveFileLastError}" IsVisible="{Binding HasIpadLiveFileLastError}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding IpadLiveFileStatus}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                  <Button Content="Backup-Ordner öffnen" Click="OpenBackupFolder_OnClick" FontSize="12" Padding="10,6" Margin="0,0,-2,-2" />
                  <Button Content="Standard-Datenordner öffnen" Click="OpenDefaultDataFolder_OnClick" FontSize="12" Padding="10,6" Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1" MinWidth="240" Padding="20" Background="{DynamicResource ContentBackgroundBrush}" IsVisible="{Binding IsTaskAreaVisible}">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,14">
          <StackPanel>
            <TextBlock Text="{Binding SelectedCategory.Name}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TaskListCaption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0" IsVisible="{Binding IsAppointmentsNavigationSelected}">
              <TextBlock Text="Zeitraum" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding AppointmentFilterOptions}"
                        SelectedItem="{Binding SelectedAppointmentFilter, Mode=TwoWay}"
                        Width="140" />
            </StackPanel>
            <TextBox Text="{Binding SearchText}"
                     AutomationProperties.Name="Aufgaben durchsuchen"
                     AutomationProperties.AutomationId="TaskSearchBox"
                     TextChanged="SearchBox_OnTextChanged"
                     PlaceholderText="Suchen nach Kunde, Titel, Adresse, Monteur, Status, Material, Anhang"
                     Margin="0,12,0,0" />
            <StackPanel Orientation="Horizontal"
                        Spacing="14"
                        Margin="0,8,0,0">
              <CheckBox IsChecked="{Binding IsGlobalSearchEnabled}"
                        Content="Alle Bereiche durchsuchen" />
              <CheckBox IsChecked="{Binding IncludeArchiveInSearch}"
                        Content="Archiv mit durchsuchen" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        Margin="0,8,0,0">
              <TextBlock Text="Sortierung:"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <ComboBox ItemsSource="{Binding SortFieldOptions}"
                        SelectedItem="{Binding SelectedSortField, Mode=TwoWay}"
                        Width="130"
                        MinHeight="28"
                        FontSize="12" />
              <Button Click="ReverseSortDirection_OnClick"
                      ToolTip.Tip="{Binding SortDirectionTooltip}"
                      Width="34"
                      Height="28"
                      MinHeight="28"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center">
                <TextBlock Text="{Binding SortDirectionGlyph}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="14"
                           LineHeight="14" />
              </Button>
            </StackPanel>
            <TextBlock Text="{Binding AutoSaveStatus}"
                       IsVisible="{Binding HasAutoSaveStatus}"
                       Foreground="{DynamicResource DangerBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0" />
            <Border Classes="Card"
                    Margin="0,10,0,0"
                    Padding="12"
                    IsVisible="{Binding IsTaskUndoPanelVisible}">
              <StackPanel Spacing="6">
                <Button Content="{Binding UndoTaskChangeText}"
                        ToolTip.Tip="{Binding UndoTaskChangeToolTip}"
                        Click="UndoTaskChange_OnClick"
                        HorizontalAlignment="Left" />
                <TextBlock Text="{Binding TaskUndoMessage}"
                           IsVisible="{Binding HasTaskUndoMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="Card"
                    IsVisible="{Binding IsMobileInboxSelected}"
                    Margin="0,10,0,0"
                    Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Verwaltung"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="Alte bereits übernommene mobile Eingänge können nach 30 Tagen aus mobile-processed entfernt werden."
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <Button Content="Alte übernommene Eingänge bereinigen"
                        Click="CleanupProcessedMobileInbox_OnClick"
                        HorizontalAlignment="Left"
                        FontSize="12" />
                <TextBlock Text="{Binding MobileInboxCleanupStatus}"
                           IsVisible="{Binding HasMobileInboxCleanupStatus}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="Card"
                    IsVisible="{Binding IsTrashSelected}"
                    Margin="0,10,0,0"
                    Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Papierkorb"
                           FontWeight="SemiBold"
                           FontSize="14" />
                <TextBlock Text="Gelöschte Aufgaben bleiben hier, bis sie wiederhergestellt oder endgültig entfernt werden."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <Button Content="Papierkorb leeren"
                        Classes="Danger"
                        Click="EmptyTrash_OnClick"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding HasTrashItems}" />
              </StackPanel>
            </Border>
          </StackPanel>
          <Button Grid.Column="1"
                  Content="Speichern"
                  Click="ManualSave_OnClick"
                  VerticalAlignment="Top"
                  Margin="0,0,8,0" />
          <Button Grid.Column="2"
                  Classes="Primary"
                  Content="Neue Aufgabe"
                  IsVisible="{Binding CanCreateTaskInSelectedCategory}"
                  Click="NewTask_OnClick"
                  VerticalAlignment="Top" />
        </Grid>

        <Border DockPanel.Dock="Top"
                Classes="Card"
                Padding="12"
                Margin="0,0,0,14"
                IsVisible="{Binding IsGlobalSearchPanelVisible}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding GlobalSearchCaption}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" />
            <ItemsControl ItemsSource="{Binding GlobalSearchResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource AccentSoftBrush}"
                          BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="{DynamicResource CornerRadiusLarge}"
                          Padding="10"
                          Margin="0,0,0,8"
                          PointerPressed="GlobalSearchResult_OnPointerPressed">
                    <StackPanel Spacing="4">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                          <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="8" Padding="8,2">
                            <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="{DynamicResource AccentBrush}" />
                          </Border>
                          <Border Background="{DynamicResource InputBackgroundBrush}"
                                  CornerRadius="8"
                                  Padding="8,2"
                                  IsVisible="{Binding IsArchived}">
                            <TextBlock Text="Archiv" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                          </Border>
                        </StackPanel>
                      </Grid>
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                      <ItemsControl ItemsSource="{Binding CategoryNameChips}"
                                    IsVisible="{Binding HasCategoryNameChips}"
                                    Margin="0,0,8,0">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{DynamicResource AccentSoftBrush}"
                                    BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="6,2"
                                    Margin="0,0,4,4">
                              <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding MatchInfo}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Classes="Card"
                Padding="12"
                Margin="0,0,0,14"
                IsVisible="{Binding HasNoVisibleMobileInboxEntries}">
          <StackPanel Spacing="4">
            <TextBlock Text="Keine mobilen Eingänge vorhanden."
                       FontWeight="SemiBold"
                       FontSize="14" />
            <TextBlock Text="Neue iPad-Eingänge mit Status new erscheinen hier, sobald sie im gemeinsamen mobile-inbox-Ordner liegen."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Classes="Card"
                Padding="12"
                Margin="0,0,0,14"
                IsVisible="{Binding IsTrashEmpty}">
          <StackPanel Spacing="4">
            <TextBlock Text="Papierkorb ist leer."
                       FontWeight="SemiBold"
                       FontSize="14" />
            <TextBlock Text="Gelöschte Aufgaben werden hier angezeigt, bis sie wiederhergestellt oder endgültig entfernt werden."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Grid x:Name="TaskTableHeaderGrid" DockPanel.Dock="Top" ColumnSpacing="8" Margin="8,0,8,4" IsVisible="{Binding IsNotAppointmentsNavigationSelected}" PointerReleased="TaskTableHeader_OnPointerReleased">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding TaskStatusColumnWidth}" />
            <ColumnDefinition Width="{Binding TaskCustomerColumnWidth}" />
            <ColumnDefinition Width="{Binding TaskLocationColumnWidth}" />
            <ColumnDefinition Width="{Binding TaskDateColumnWidth}" />
            <ColumnDefinition Width="{Binding TaskTechnicianColumnWidth}" />
          </Grid.ColumnDefinitions>
          <Grid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Titel ein-/ausblenden" Click="ToggleTaskTitleColumn_OnClick" />
              <MenuItem Header="Standard wiederherstellen" Click="ResetTaskTableColumns_OnClick" />
            </ContextMenu>
          </Grid.ContextMenu>
          <TextBlock Text="Status" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="1" Text="Kunde" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="2" Text="Ort" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="3" Text="Termin" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="4" Text="Techniker" Classes="TaskTableHeader" />
          <GridSplitter Grid.Column="0" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="2" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
        </Grid>
        <Grid x:Name="AppointmentTableHeaderGrid" DockPanel.Dock="Top" ColumnSpacing="8" Margin="8,0,8,4" IsVisible="{Binding IsAppointmentsNavigationSelected}" PointerReleased="TaskTableHeader_OnPointerReleased">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding AppointmentDateColumnWidth}" />
            <ColumnDefinition Width="{Binding AppointmentTimeColumnWidth}" />
            <ColumnDefinition Width="{Binding AppointmentStatusColumnWidth}" />
            <ColumnDefinition Width="{Binding AppointmentCustomerColumnWidth}" />
            <ColumnDefinition Width="{Binding AppointmentLocationColumnWidth}" />
            <ColumnDefinition Width="{Binding AppointmentTechnicianColumnWidth}" />
          </Grid.ColumnDefinitions>
          <Grid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Titel ein-/ausblenden" Click="ToggleTaskTitleColumn_OnClick" />
              <MenuItem Header="Standard wiederherstellen" Click="ResetTaskTableColumns_OnClick" />
            </ContextMenu>
          </Grid.ContextMenu>
          <TextBlock Text="Datum" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="1" Text="Uhrzeit" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="2" Text="Status" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="3" Text="Kunde" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="4" Text="Ort" Classes="TaskTableHeader" />
          <TextBlock Grid.Column="5" Text="Techniker" Classes="TaskTableHeader" />
          <GridSplitter Grid.Column="0" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="2" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
          <GridSplitter Grid.Column="4" Width="6" HorizontalAlignment="Right" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" Background="{DynamicResource BorderBrushDark}" />
        </Grid>
        <ListBox x:Name="TaskList"
                 AutomationProperties.Name="Vorgangstabelle"
                 AutomationProperties.AutomationId="TaskList"
                 ItemsSource="{Binding VisibleTasks}"
                 SelectedItem="{Binding SelectedTask}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionChanged="TaskList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <Border Classes="TaskCard"
                      Margin="0,0,0,3"
                      Padding="8,7"
                      IsVisible="{Binding $parent[Window].DataContext.IsAppointmentsNavigationSelected}">
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentDateColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentTimeColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentStatusColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentCustomerColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentLocationColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.AppointmentTechnicianColumnWidth}" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding DueDateDateText}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding DueDateTimeText}" VerticalAlignment="Center" />
                  <Border Grid.Column="2" Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusSmall}" Padding="6,2" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding WorkflowStatusText}" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                  </Border>
                  <TextBlock Grid.Column="3" Text="{Binding CustomerName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding CustomerName}" />
                  <TextBlock Grid.Column="4" Text="{Binding CustomerAddress}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding CustomerAddress}" />
                  <TextBlock Grid.Column="5" Text="{Binding TechnicianDisplayText}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Grid>
                </Border>
                <Border Classes="TaskCard"
                      Margin="0,0,0,3"
                      Padding="8,7"
                      IsVisible="{Binding $parent[Window].DataContext.IsNotAppointmentsNavigationSelected}">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Wiedervorlage bestätigen"
                              IsVisible="{Binding HasFollowUpDate}"
                              Click="ConfirmFollowUp_OnClick" />
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.TaskStatusColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.TaskCustomerColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.TaskLocationColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.TaskDateColumnWidth}" />
                    <ColumnDefinition Width="{Binding $parent[Window].DataContext.TaskTechnicianColumnWidth}" />
                  </Grid.ColumnDefinitions>
                  <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentSoftBorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource CornerRadiusSmall}" Padding="6,2" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding WorkflowStatusText}" FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding CustomerName}" />
                    <TextBlock Text="{Binding Title}" IsVisible="{Binding $parent[Window].DataContext.ShowTaskTitleColumn}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Title}" />
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding CustomerAddress}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="3" Text="{Binding DueDateText}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="4" Text="{Binding TechnicianDisplayText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding TechnicianDisplayText}" />
                </Grid>
                </Border>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <GridSplitter Grid.Column="2"
                  Width="6"
                  MinWidth="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ResizeBehavior="PreviousAndNext"
                  ShowsPreview="False"
                  Background="{DynamicResource BorderBrushDark}"
                  PointerReleased="RootLayoutGrid_OnPointerReleased"
                  IsVisible="{Binding IsTaskAreaVisible}"
                  ToolTip.Tip="Detailbereich verschieben" />

    <Border Grid.Column="3" MinWidth="280"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1,0,0,0"
            IsVisible="{Binding IsTaskAreaVisible}">
      <ScrollViewer>
        <StackPanel>
        <StackPanel Margin="24" Spacing="10" IsVisible="{Binding HasSelectedMobileInboxEntry}">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Text="Mobiler Eingang" FontSize="24" FontWeight="SemiBold" />
            <Border Grid.Column="1"
                    Background="{DynamicResource AccentSoftBrush}"
                    BorderBrush="{DynamicResource AccentSoftBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8,4"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding SelectedMobileInboxEntry.DisplayStatusText}"
                         FontSize="12"
                         Foreground="{DynamicResource AccentBrush}" />
            </Border>
          </Grid>

          <TextBlock Text="Dieser Eingang wird nur gelesen und noch nicht in die Auftragsdatenbank übernommen."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,-4,0,2" />

          <Button Content="In BüroCockpit übernehmen"
                  Classes="Primary"
                  HorizontalAlignment="Left"
                  Click="ImportMobileInboxEntry_OnClick" />

          <TextBlock Text="{Binding SelectedMobileInboxEntry.MobileAttachmentOverviewText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     TextWrapping="Wrap" />

          <Border Classes="Card"
                  IsVisible="{Binding SelectedMobileInboxEntry.HasAttachmentIssueText}"
                  Padding="12"
                  BorderBrush="{DynamicResource DangerBrush}">
            <TextBlock Text="{Binding SelectedMobileInboxEntry.AttachmentIssueText}"
                       Foreground="{DynamicResource DangerBrush}"
                       FontSize="12"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="SectionTitle" Text="Besichtigung" />
          <Border Classes="Card" Padding="14">
            <StackPanel Spacing="8">
              <TextBlock Text="Kunde" Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="{Binding SelectedMobileInboxEntry.DisplayCustomerName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />

              <TextBlock Text="Titel" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBlock Text="{Binding SelectedMobileInboxEntry.DisplayTitle}"
                         TextWrapping="Wrap" />

              <TextBlock Text="Erstellt" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBlock Text="{Binding SelectedMobileInboxEntry.CreatedAtText}" />

              <TextBlock Text="Adresse" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBlock Text="{Binding SelectedMobileInboxEntry.Address}"
                         TextWrapping="Wrap" />

              <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Telefon" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding SelectedMobileInboxEntry.Phone}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="E-Mail" Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="{Binding SelectedMobileInboxEntry.Email}" TextWrapping="Wrap" />
                </StackPanel>
              </Grid>

              <TextBlock Text="Notiz" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
              <TextBlock Text="{Binding SelectedMobileInboxEntry.Notes}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <TextBlock Classes="SectionTitle" Text="Fotos" Margin="0,12,0,0" />
          <Border Classes="Card"
                  IsVisible="{Binding HasMobileInboxPhotoPreviews}"
                  Padding="12">
            <ItemsControl ItemsSource="{Binding MobileInboxPhotoPreviews}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Tag="{Binding}"
                          Click="ShowMobileInboxPreview_OnClick"
                          Padding="0"
                          Margin="0,0,8,8"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Width="190"
                            MinHeight="172"
                            CornerRadius="8"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Padding="8">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding DisplayKind}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <Border Height="112"
                                CornerRadius="6"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                ClipToBounds="True">
                          <Grid>
                            <Image Source="{Binding Path, Converter={StaticResource ThumbnailImageConverter}}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   IsVisible="{Binding HasPreviewImage}" />
                            <TextBlock Text="{Binding StatusText}"
                                       IsVisible="{Binding HasPreviewMessage}"
                                       Foreground="{DynamicResource DangerBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="8"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                          </Grid>
                        </Border>
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
          <Border Classes="Card"
                  IsVisible="{Binding HasNoMobileInboxPhotoPreviews}"
                  Padding="12">
            <TextBlock Text="Keine Foto-Vorschauen vorhanden."
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>

          <TextBlock Classes="SectionTitle" Text="Skizzen" Margin="0,12,0,0" />
          <Border Classes="Card"
                  IsVisible="{Binding HasMobileInboxSketchPreviews}"
                  Padding="12">
            <ItemsControl ItemsSource="{Binding MobileInboxSketchPreviews}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Tag="{Binding}"
                          Click="ShowMobileInboxPreview_OnClick"
                          Padding="0"
                          Margin="0,0,8,8"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Width="190"
                            MinHeight="172"
                            CornerRadius="8"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Padding="8">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding DisplayKind}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <Border Height="112"
                                CornerRadius="6"
                                Background="{DynamicResource SurfaceElevatedBrush}"
                                ClipToBounds="True">
                          <Grid>
                            <Image Source="{Binding Path, Converter={StaticResource ThumbnailImageConverter}}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   IsVisible="{Binding HasPreviewImage}" />
                            <TextBlock Text="{Binding StatusText}"
                                       IsVisible="{Binding HasPreviewMessage}"
                                       Foreground="{DynamicResource DangerBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="8"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                          </Grid>
                        </Border>
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
          <Border Classes="Card"
                  IsVisible="{Binding HasNoMobileInboxSketchPreviews}"
                  Padding="12">
            <TextBlock Text="Keine Skizzen-Vorschauen vorhanden."
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>

          <TextBlock Classes="SectionTitle" Text="Dateien" Margin="0,12,0,0" />
          <Border Classes="Card"
                  IsVisible="{Binding HasMobileInboxFilePreviews}"
                  Padding="12">
            <ItemsControl ItemsSource="{Binding MobileInboxFilePreviews}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Tag="{Binding}"
                          Click="ShowMobileInboxPreview_OnClick"
                          Padding="0"
                          Margin="0,0,8,8"
                          Background="Transparent"
                          BorderThickness="0">
                    <Border Width="190"
                            MinHeight="120"
                            CornerRadius="8"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Padding="8">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding DisplayKind}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DetailStatusText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
          <Border Classes="Card"
                  IsVisible="{Binding HasNoMobileInboxFilePreviews}"
                  Padding="12">
            <TextBlock Text="Keine sonstigen Dateien vorhanden."
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>

          <Border Classes="Card"
                  IsVisible="{Binding HasSelectedMobileInboxPreviewItem}"
                  Padding="14"
                  Margin="0,12,0,0">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding SelectedMobileInboxPreviewItem.DisplayKind}"
                             FontWeight="SemiBold"
                             FontSize="16"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedMobileInboxPreviewItem.DetailFileName}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Schließen"
                        Click="CloseMobileInboxPreview_OnClick" />
              </Grid>
              <Border Height="360"
                      CornerRadius="8"
                      Background="{DynamicResource SurfaceElevatedBrush}"
                      ClipToBounds="True"
                      IsVisible="{Binding SelectedMobileInboxPreviewItem.IsDefaultPreview}">
                <Grid>
                  <Image Source="{Binding MobileInboxPreviewDetailPath, Converter={StaticResource ThumbnailImageConverter}}"
                         Stretch="Uniform"
                         RenderOptions.BitmapInterpolationMode="HighQuality"
                         IsVisible="{Binding HasMobileInboxPreviewDetailImage}" />
                  <TextBlock Text="{Binding MobileInboxPreviewDetailMessage}"
                             IsVisible="{Binding HasMobileInboxPreviewDetailMessage}"
                             Foreground="{DynamicResource DangerBrush}"
                             TextWrapping="Wrap"
                             Margin="16"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center" />
                </Grid>
              </Border>
              <Border Height="360"
                      CornerRadius="8"
                      Background="{DynamicResource InputBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      ClipToBounds="True"
                      IsVisible="{Binding SelectedMobileInboxPreviewItem.IsSketchPreview}">
                <Grid>
                  <Image Source="{Binding MobileInboxPreviewDetailPath, Converter={StaticResource ThumbnailImageConverter}}"
                         Stretch="Uniform"
                         RenderOptions.BitmapInterpolationMode="HighQuality"
                         IsVisible="{Binding HasMobileInboxPreviewDetailImage}" />
                  <TextBlock Text="{Binding MobileInboxPreviewDetailMessage}"
                             IsVisible="{Binding HasMobileInboxPreviewDetailMessage}"
                             Foreground="{DynamicResource DangerBrush}"
                             TextWrapping="Wrap"
                             Margin="16"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center" />
                </Grid>
              </Border>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Öffnen"
                        IsEnabled="{Binding CanOpenSelectedMobileInboxPreview}"
                        Click="OpenMobileInboxPreview_OnClick" />
                <Button Content="Im Ordner anzeigen"
                        IsEnabled="{Binding CanOpenSelectedMobileInboxPreview}"
                        Click="ShowMobileInboxPreviewInFolder_OnClick" />
              </StackPanel>
              <TextBlock Text="{Binding MobileInboxPreviewStatus}"
                         IsVisible="{Binding HasMobileInboxPreviewStatus}"
                         Foreground="{DynamicResource DangerBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Classes="TaskDetailRoot" Margin="24" Spacing="14" IsVisible="{Binding HasNormalSelectedTask}">
          <Border Classes="TaskDetailHeader">
            <Grid RowDefinitions="Auto,Auto">
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedTask.CustomerName, StringFormat='Kunde: {0}'}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding SelectedTask.Title}"
                           Classes="TaskDetailSubtitle" />
              </StackPanel>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                <Button Content="Speichern und prüfen" Classes="Primary" Click="SaveTask_OnClick" />
                <Button Content="Wiederherstellen" Click="RestoreTask_OnClick" IsVisible="{Binding IsTrashSelected}" />
                <Button Content="Löschen" Classes="Danger" Click="DeleteTask_OnClick" IsVisible="{Binding IsNotTrashSelected}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="TaskDetailCard">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Text="Status" Classes="TaskDetailFieldLabel" />
                  <ComboBox ItemsSource="{Binding WorkflowStatusOptions}"
                            SelectedItem="{Binding SelectedTask.WorkflowStep, Mode=TwoWay}"
                            SelectionChanged="StatusCombo_OnSelectionChanged" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding SelectedTask.WorkflowType}" Classes="TaskDetailSubtitle" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Text="Ablauf" Classes="TaskDetailFieldLabel" />
              <ItemsControl ItemsSource="{Binding WorkflowSteps}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Tag="{Binding Name}"
                            Click="WorkflowStep_OnClick"
                            Classes="Tertiary"
                            Margin="0,0,6,6"
                            Padding="9,5">
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="●" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="{Binding Name}" FontSize="12" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="Der aktuelle Schritt wird gespeichert; bestehende Kategorien bleiben unverändert."
                         Classes="TaskDetailSubtitle" />
            </StackPanel>
          </Border>

          <Border Classes="TaskDetailInset">
            <TextBlock Text="Hinweis: Ähnliche Aufträge werden beim Speichern geprüft."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </Border>

          <TextBlock Classes="TaskDetailSectionTitle" Text="Aufgabe" />
          <Border Classes="TaskDetailCard">
            <StackPanel Spacing="8">
              <TextBlock Text="Kunde" Classes="TaskDetailFieldLabel" />
              <TextBox Text="{Binding SelectedTask.CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Kundenname" GotFocus="TaskDetailEditor_OnGotFocus" />

              <TextBlock Text="Kundenadresse" Classes="TaskDetailFieldLabel" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.CustomerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Adresse"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="64"
                       GotFocus="TaskDetailEditor_OnGotFocus" />

              <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                <StackPanel Spacing="6">
                  <TextBlock Text="Kunden-E-Mail" Classes="TaskDetailFieldLabel" />
                  <TextBox Text="{Binding SelectedTask.CustomerEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="E-Mail-Adresse"
                           GotFocus="TaskDetailEditor_OnGotFocus" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="Telefonnummer" Classes="TaskDetailFieldLabel" />
                  <TextBox Text="{Binding SelectedTask.CustomerPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="Telefonnummer"
                           GotFocus="TaskDetailEditor_OnGotFocus" />
                </StackPanel>
              </Grid>

              <TextBlock Text="Titel" Classes="TaskDetailFieldLabel" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Kurzer Aufgabentitel" GotFocus="TaskDetailEditor_OnGotFocus" />

              <TextBlock Text="Beschreibung / Notiz" Classes="TaskDetailFieldLabel" Margin="0,6,0,0" />
              <TextBox Text="{Binding SelectedTask.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Notizen, Verlauf, offene Punkte"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="110"
                       GotFocus="TaskDetailEditor_OnGotFocus" />
            </StackPanel>
          </Border>

          <TextBlock Classes="TaskDetailSectionTitle" Text="Organisation" />
          <Border Classes="TaskDetailCard">
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Monteur" Classes="TaskDetailFieldLabel" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="Gesendet am" Classes="TaskDetailFieldLabel" />
              <TextBlock Grid.Row="0" Grid.Column="2" Text="Material bestellt am" Classes="TaskDetailFieldLabel" />

              <ComboBox Grid.Row="1"
                        Grid.Column="0"
                        ItemsSource="{Binding TechnicianOptions}"
                        SelectedItem="{Binding SelectedTechnicianOption, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        GotFocus="TaskDetailEditor_OnGotFocus"
                        SelectionChanged="TechnicianCombo_OnSelectionChanged" />

              <TextBox Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding SentAtInputText}"
                       Tag="SentAt"
                       PlaceholderText="TT.MM.JJJJ"
                       GotFocus="TaskDetailEditor_OnGotFocus"
                       LostFocus="SentAtTextBox_OnLostFocus"
                       TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />

              <TextBox Grid.Row="1"
                       Grid.Column="2"
                       Text="{Binding MaterialOrderedAtInputText}"
                       Tag="MaterialOrderedAt"
                       PlaceholderText="TT.MM.JJJJ"
                       GotFocus="TaskDetailEditor_OnGotFocus"
                       LostFocus="MaterialOrderedAtTextBox_OnLostFocus"
                       TextChanged="DateTextBox_OnTextChanged"
                       KeyDown="DateTextBox_OnKeyDown" />
              <CheckBox Grid.Row="2" Grid.ColumnSpan="3" Margin="0,6,0,0"
                        Content="Auf den Schreibtisch legen"
                        IsChecked="{Binding IsSelectedTaskOnDesk, Mode=TwoWay}" />
            </Grid>
          </Border>

          <Border Classes="TaskDetailCard"
                  IsVisible="{Binding SelectedTask.HasCategoryNameChips}">
            <StackPanel Spacing="8">
              <TextBlock Text="Zugeordnete Kategorien" Classes="TaskDetailFieldLabel" />
              <ItemsControl ItemsSource="{Binding SelectedTask.CategoryNameChips}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="TaskDetailChip"
                            Margin="0,0,4,4">
                      <TextBlock Text="{Binding}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <TextBlock Classes="TaskDetailSectionTitle" Text="Kategorien" />
          <Border Classes="TaskDetailCard">
            <ItemsControl ItemsSource="{Binding TaskCategorySelections}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox Content="{Binding Name}"
                            IsChecked="{Binding IsSelected}"
                            Margin="0,0,16,8"
                            Click="TaskCategoryCheckBox_OnChanged" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <TextBlock Classes="TaskDetailSectionTitle" Text="Termine" />
          <Border Classes="TaskDetailCard">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="2*,*,2*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                <TextBlock Text="Termin" Classes="TaskDetailFieldLabel" />
                <TextBlock Grid.Column="1" Text="Uhrzeit" Classes="TaskDetailFieldLabel" />
                <TextBlock Grid.Column="2" Text="Wiedervorlage" Classes="TaskDetailFieldLabel" />
                <StackPanel Grid.Row="1" Spacing="6">
                  <TextBox Text="{Binding DueDateInputText}"
                           Tag="DueDate"
                           PlaceholderText="TT.MM.JJJJ"
                           GotFocus="TaskDetailEditor_OnGotFocus"
                           LostFocus="DueDateTextBox_OnLostFocus"
                           TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                  <TextBox Text="{Binding DueTimeInputText}"
                           Tag="DueTime"
                           PlaceholderText="HH:MM"
                           GotFocus="TaskDetailEditor_OnGotFocus"
                           LostFocus="DueTimeTextBox_OnLostFocus"
                           KeyDown="DateTextBox_OnKeyDown" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="6">
                  <TextBox Text="{Binding FollowUpDateInputText}"
                           Tag="FollowUpDate"
                           PlaceholderText="TT.MM.JJJJ"
                           GotFocus="TaskDetailEditor_OnGotFocus"
                           LostFocus="FollowUpDateTextBox_OnLostFocus"
                           TextChanged="DateTextBox_OnTextChanged"
                           KeyDown="DateTextBox_OnKeyDown" />
                </StackPanel>
              </Grid>
              <TextBlock Text="{Binding DateInputMessage}"
                         IsVisible="{Binding HasDateInputMessage}"
                         Foreground="{DynamicResource DangerBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Classes="TaskDetailSectionTitle" Text="Material" Margin="0" />
            <Button Grid.Column="1" Content="+ Material hinzufügen" Click="AddMaterial_OnClick" />
          </Grid>
          <TextBlock Text="Materialpositionen für diesen Auftrag."
                     Classes="TaskDetailSubtitle"
                     Margin="0,-6,0,0" />

          <Border Classes="TaskDetailCard"
                  IsVisible="{Binding HasNoMaterials}"
                  Margin="0,0,0,8">
            <TextBlock Text="Noch kein Material erfasst." Foreground="{DynamicResource TextSecondaryBrush}" />
          </Border>

          <ItemsControl ItemsSource="{Binding Materials}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="TaskDetailCard" Margin="0,0,0,8">
                  <Grid ColumnDefinitions="120,78,*,132,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Text="Menge" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Einheit" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="2" Text="Bezeichnung" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <TextBlock Grid.Column="3" Text="Status" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" />
                    <NumericUpDown Grid.Row="1" Value="{Binding Quantity}" Minimum="0" Increment="1" Width="112" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Unit}" />
                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Name}" PlaceholderText="Material" />
                    <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding $parent[Window].DataContext.MaterialStatusOptions}" SelectedItem="{Binding Status}" />
                    <Button Grid.Row="1" Grid.Column="4" Content="×" Click="DeleteMaterial_OnClick" Tag="{Binding}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

              <Border Classes="Card"
                  IsVisible="{Binding HasSelectedAttachment}"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="SectionTitle" Text="Vorschau" Margin="0" VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="PreviewClose"
                        Click="ClosePreview_OnClick">
                  <TextBlock Text="×"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             TextAlignment="Center"
                             FontSize="14"
                             Margin="0,-1,0,0" />
                </Button>
              </Grid>

                      <Border MinHeight="220"
                      MaxHeight="520"
                      CornerRadius="{DynamicResource CornerRadiusLarge}"
                      Background="{DynamicResource InputBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      ClipToBounds="True">
                <Grid>
                  <Image IsVisible="{Binding HasPreviewImage}"
                         Source="{Binding PreviewImagePath, Converter={StaticResource ThumbnailImageConverter}}"
                         Stretch="Uniform"
                         MaxWidth="420"
                         MaxHeight="520"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                  <TextBlock IsVisible="{Binding HasPreviewPlaceholder}"
                             Text="{Binding SelectedAttachment.FileTypeBadge}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="28"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
              </Border>

	              <StackPanel Spacing="0">
	                <TextBlock Text="{Binding AttachmentPreviewTitle}" FontWeight="SemiBold" TextWrapping="Wrap" />
	                <TextBlock Text="{Binding AttachmentPreviewInfo}"
	                           Foreground="{DynamicResource TextSecondaryBrush}"
	                           FontSize="12"
	                           Margin="0,3,0,0"
	                           TextWrapping="Wrap" />
	              </StackPanel>

              <Border Background="{DynamicResource InputBackgroundBrush}"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource CornerRadiusLarge}"
                      Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="iPad-Bearbeitung"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="Beim Übernehmen wird diese Anlage aktualisiert. Die alte Version wird gesichert."
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Content="Für iPad bereitstellen"
                            Click="ExportAttachmentForIpad_OnClick"
                            Margin="0,0,-2,-2" />
                    <Button Content="Änderungen prüfen"
                            Click="CheckIpadChanges_OnClick"
                            Margin="0,0,-2,-2" />
                    <Button Content="Bearbeitung übernehmen"
                            Classes="Primary"
                            IsVisible="{Binding CanImportAttachmentEdit}"
                            Click="ImportIpadChanges_OnClick"
                            Margin="0,0,0,8" />
                  </WrapPanel>
                  <TextBlock Text="{Binding AttachmentEditStatus}"
                             IsVisible="{Binding HasAttachmentEditStatus}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Classes="TaskDetailSectionTitle" Text="Anhänge" Margin="0" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Content="Ausgewählte drucken" Click="PrintSelectedAttachments_OnClick" />
              <Button Content="Datei anhängen" Click="AddAttachment_OnClick" />
            </StackPanel>
          </Grid>
          <TextBlock Text="Dateien, Fotos und PDFs zum Auftrag."
                     Classes="TaskDetailSubtitle"
                     Margin="0,-6,0,0" />

          <Border Classes="TaskDetailInset"
                  Margin="0,0,0,10"
                  DragDrop.AllowDrop="True"
                  DragDrop.DragOver="AttachmentDropZone_OnDragOver"
                  DragDrop.Drop="AttachmentDropZone_OnDrop">
            <TextBlock Text="Dateien hier ablegen oder über „Datei anhängen“ auswählen"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </Border>

          <ItemsControl ItemsSource="{Binding Attachments}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="TaskDetailCard"
                        Margin="0,0,0,8"
                        Background="{DynamicResource SurfaceBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        PointerPressed="AttachmentCard_OnPointerPressed">
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Extern öffnen"
                                Click="OpenAttachmentExternal_OnClick" />
                      <MenuItem Header="Datei neu zuordnen"
                                Click="ReassignAttachmentFile_OnClick" />
                      <MenuItem Header="Entfernen"
                                Click="DeleteAttachment_OnClick"
                                Tag="{Binding}" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="170,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="160" Height="110" CornerRadius="{DynamicResource CornerRadiusLarge}" Background="{DynamicResource InputBackgroundBrush}" ClipToBounds="True">
                      <Grid>
                        <Image IsVisible="{Binding HasThumbnail}"
                               Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailImageConverter}}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <TextBlock IsVisible="{Binding HasNoThumbnail}"
                                   Text="{Binding FileTypeBadge}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                      </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding FileDisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding FileTypeBadge}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                      <TextBlock Text="{Binding FileStatusText}"
                                 IsVisible="{Binding HasMissingFile}"
                                 Foreground="{DynamicResource DangerBrush}"
                                 FontSize="12"
                                 Margin="0,4,0,0"
                                 TextWrapping="Wrap" />
                    </StackPanel>
	                    <StackPanel Grid.Column="2" Spacing="8">
	                      <Button Content="Extern öffnen"
	                              Click="OpenAttachmentExternalFromList_OnClick" />
	                      <Button Content="Auf Schreibtisch legen"
	                              Click="PlaceAttachmentOnDesk_OnClick" />
	                      <Button Content="Entfernen" Click="DeleteAttachment_OnClick" Tag="{Binding}" />
	                      <CheckBox IsChecked="{Binding IsSelectedForPrint, Mode=TwoWay}"
	                                Content="Auswählen"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

  </Grid>
</Window>
