<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BueroCockpit.Converters"
        x:Class="BueroCockpit.MainWindow"
        x:CompileBindings="False"
        Width="1280"
        Height="780"
        MinWidth="1080"
        MinHeight="680"
        Background="#F5F5F7"
        Title="BueroCockpit">
  <Window.Resources>
    <converters:ThumbnailImageConverter x:Key="ThumbnailImageConverter" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#1D1D1F" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#6E6E73" />
      <Setter Property="Margin" Value="0,14,0,8" />
    </Style>
    <Style Selector="TextBox, ComboBox, DatePicker, NumericUpDown">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#D8D8DD" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8D8DD" />
      <Setter Property="Foreground" Value="#1D1D1F" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Button:focus-visible">
      <Setter Property="BorderBrush" Value="#8DBEFF" />
    </Style>
    <Style Selector="Button.Primary">
      <Setter Property="Background" Value="#1F6FEB" />
      <Setter Property="BorderBrush" Value="#1F6FEB" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.Danger">
      <Setter Property="Foreground" Value="#B42318" />
    </Style>
    <Style Selector="Button.PreviewClose">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8D8DD" />
      <Setter Property="Foreground" Value="#6E6E73" />
      <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#TaskList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox#CategoryList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.Card">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E0E0E5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="240,430,*">
    <Border Grid.Column="0"
            Background="#ECECF0"
            BorderBrush="#D8D8DD"
            BorderThickness="0,0,1,0"
            Padding="18">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
          <TextBlock Text="BueroCockpit" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="Lokale Aufgaben" Foreground="#6E6E73" Margin="1,3,0,0" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom"
                Background="#F7F7F9"
                BorderBrush="#D8D8DD"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Margin="0,16,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="Kategorie" FontWeight="SemiBold" Foreground="#6E6E73" FontSize="12" />
            <TextBox Text="{Binding CategoryEditorName}"
                     TextChanged="CategoryEditor_OnTextChanged"
                     PlaceholderText="Name" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <Button Content="+ Neu" Click="AddCategory_OnClick" />
              <Button Grid.Column="1" Content="Ändern" Click="RenameCategory_OnClick" />
            </Grid>
            <Button Content="Löschen" Click="HideCategory_OnClick" />
            <TextBlock Text="{Binding CategoryMessage}"
                       IsVisible="{Binding HasCategoryMessage}"
                       Foreground="#6E6E73"
                       FontSize="12"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <ListBox x:Name="CategoryList"
                 ItemsSource="{Binding Categories}"
                 SelectedItem="{Binding SelectedCategory}"
                 SelectionChanged="CategoryList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="9"
                      Padding="10,9"
                      Background="{Binding SidebarBackground}"
                      BorderBrush="{Binding SidebarBorderBrush}"
                      BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="8" Padding="7,2">
                    <TextBlock Text="{Binding TaskCount}" FontSize="12" Foreground="#6E6E73" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="2"
            Padding="26"
            Background="#F5F5F7"
            IsVisible="{Binding IsOverviewSelected}">
      <ScrollViewer>
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Übersicht" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding DashboardDateText}" Foreground="#6E6E73" Margin="0,5,0,0" />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding DashboardSections}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="Card"
                        Width="330"
                        MinHeight="210"
                        Margin="0,0,14,14">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" />
                      <Border Grid.Column="1" Background="#F2F3F5" CornerRadius="10" Padding="9,3">
                        <TextBlock Text="{Binding Count}" FontWeight="SemiBold" Foreground="#525257" />
                      </Border>
                    </Grid>

                    <TextBlock Text="Keine Aufgaben."
                               IsVisible="{Binding HasNoTasks}"
                               Foreground="#86868B"
                               Margin="0,10,0,0" />

                    <ItemsControl ItemsSource="{Binding Tasks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#F7F8FA"
                                  BorderBrush="#E5E5EA"
                                  BorderThickness="1"
                                  CornerRadius="10"
                                  Padding="10"
                                  Margin="0,0,0,8"
                                  PointerPressed="DashboardTask_OnPointerPressed">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Title}" Foreground="#38383D" TextWrapping="Wrap" />
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding Status}" Foreground="#6E6E73" FontSize="12" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DueDateText, StringFormat='Termin: {0}'}"
                                           Foreground="#6E6E73"
                                           FontSize="12" />
                              </Grid>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1"
            Grid.ColumnSpan="2"
            Padding="26"
            Background="#F5F5F7"
            IsVisible="{Binding IsSettingsSelected}">
      <ScrollViewer>
        <StackPanel Spacing="18">
          <StackPanel>
            <TextBlock Text="Einstellungen" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Datenspeicher und lokale Sicherungen" Foreground="#6E6E73" Margin="0,5,0,0" />
          </StackPanel>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="Datenordner" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="App-Datenordner" Foreground="#86868B" FontSize="12" />
              <TextBlock Text="{Binding AppDataDirectory}" TextWrapping="Wrap" />
              <TextBlock Text="Datenbank" Foreground="#86868B" FontSize="12" Margin="0,8,0,0" />
              <TextBlock Text="{Binding DatabasePath}" TextWrapping="Wrap" />
              <TextBlock Text="Aufgaben-/Anhangsordner" Foreground="#86868B" FontSize="12" Margin="0,8,0,0" />
              <TextBlock Text="{Binding TasksDirectory}" TextWrapping="Wrap" />
              <TextBlock Text="Backup-Ordner" Foreground="#86868B" FontSize="12" Margin="0,8,0,0" />
              <TextBlock Text="{Binding BackupDirectory}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                <Button Content="Datenordner öffnen" Click="OpenDataFolder_OnClick" />
                <Button Grid.Column="1" Content="Backup-Ordner öffnen" Click="OpenBackupFolder_OnClick" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <TextBlock Text="OneDrive / iPad-Bearbeitung" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="OneDrive-Bearbeitungsordner" Foreground="#86868B" FontSize="12" />
              <TextBlock Text="{Binding OneDriveEditDirectory}"
                         IsVisible="{Binding HasOneDriveEditDirectory}"
                         TextWrapping="Wrap" />
              <TextBlock Text="Noch kein OneDrive-Bearbeitungsordner gewählt."
                         IsVisible="{Binding HasNoOneDriveEditDirectory}"
                         Foreground="#6E6E73"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                <Button Content="OneDrive-Ordner auswählen" Click="SelectOneDriveFolder_OnClick" />
                <Button Grid.Column="1" Content="OneDrive-Ordner öffnen" Click="OpenOneDriveFolder_OnClick" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="Card">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Backup" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Backup erstellen" Classes="Primary" Click="CreateBackup_OnClick" />
              </Grid>
              <TextBlock Text="{Binding BackupStatus}" Foreground="#38383D" TextWrapping="Wrap" />
              <TextBlock Text="{Binding LastBackupTime, StringFormat='Letztes Backup: {0}'}"
                         IsVisible="{Binding HasLastBackup}"
                         Foreground="#6E6E73" />
              <TextBlock Text="{Binding LastBackupPath}"
                         IsVisible="{Binding HasLastBackup}"
                         Foreground="#6E6E73"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Column="1" Padding="20" Background="#F5F5F7" IsVisible="{Binding IsTaskAreaVisible}">
      <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
          <StackPanel>
            <TextBlock Text="{Binding SelectedCategory.Name}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TaskListCaption}" Foreground="#6E6E73" Margin="0,4,0,0" />
            <TextBox Text="{Binding SearchText}"
                     TextChanged="SearchBox_OnTextChanged"
                     PlaceholderText="Suchen nach Kunde, Titel, Notiz, Zuständigem, Material"
                     Margin="0,12,0,0" />
          </StackPanel>
          <Button Grid.Column="1" Classes="Primary" Content="Neue Aufgabe" Click="NewTask_OnClick" />
        </Grid>

        <ListBox x:Name="TaskList"
                 ItemsSource="{Binding VisibleTasks}"
                 SelectedItem="{Binding SelectedTask}"
                 SelectionChanged="TaskList_OnSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="Card"
                      Margin="0,0,0,10"
                      Background="{Binding CardBackground}"
                      BorderBrush="{Binding CardBorderBrush}">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="15" />
                    <Border Grid.Column="1" Background="#F2F3F5" CornerRadius="8" Padding="8,3">
                      <TextBlock Text="{Binding Priority}" FontSize="12" Foreground="#525257" />
                    </Border>
                  </Grid>
                  <TextBlock Text="{Binding Title}" Foreground="#38383D" TextWrapping="Wrap" />
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                    <TextBlock Text="Status" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Termin" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Row="1" Text="{Binding Status}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DueDateText}" />
                  </Grid>
                  <TextBlock Text="{Binding FollowUpDateText, StringFormat='Wiedervorlage: {0}'}"
                             Foreground="#6E6E73" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Column="2"
            Background="#FFFFFF"
            BorderBrush="#E0E0E5"
            BorderThickness="1,0,0,0"
            IsVisible="{Binding IsTaskAreaVisible}">
      <ScrollViewer>
        <StackPanel Margin="24" Spacing="10" IsVisible="{Binding HasSelectedTask}">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
            <TextBlock Text="Details" FontSize="24" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Duplizieren" Click="DuplicateTask_OnClick" Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="Speichern" Classes="Primary" Click="SaveTask_OnClick" Margin="0,0,8,0" />
            <Button Grid.Column="3" Content="Löschen" Classes="Danger" Click="DeleteTask_OnClick" />
          </Grid>

          <TextBlock Classes="SectionTitle" Text="Aufgabe" />
          <TextBlock Text="Kunde" />
          <TextBox Text="{Binding SelectedTask.CustomerName}" PlaceholderText="Kundenname" />
          <TextBlock Text="Titel" />
          <TextBox Text="{Binding SelectedTask.Title}" PlaceholderText="Kurzer Aufgabentitel" />
          <TextBlock Text="Beschreibung / Notiz" />
          <TextBox Text="{Binding SelectedTask.Description}" PlaceholderText="Notizen, Verlauf, offene Punkte"
                   AcceptsReturn="True" TextWrapping="Wrap" MinHeight="110" />

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Kategorie" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Status" />
            <ComboBox Grid.Row="1" Grid.Column="0"
                      ItemsSource="{Binding TaskCategories}"
                      SelectedItem="{Binding SelectedTaskCategory}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding SelectedTask.Status}"
                      SelectionChanged="StatusCombo_OnSelectionChanged" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Priorität" Margin="0,8,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="Monteur / Zuständig" Margin="0,8,0,0" />
            <ComboBox Grid.Row="3" Grid.Column="0" ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedTask.Priority}" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTask.AssignedTo}" />
          </Grid>

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">
            <TextBlock Text="Termin" />
            <TextBlock Grid.Column="1" Text="Wiedervorlage" />
            <DatePicker Grid.Row="1" SelectedDate="{Binding SelectedDueDate}" />
            <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding SelectedFollowUpDate}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Classes="SectionTitle" Text="Material" Margin="0" />
            <Button Grid.Column="1" Content="+ Material" Click="AddMaterial_OnClick" />
          </Grid>

          <Border Classes="Card"
                  IsVisible="{Binding HasNoMaterials}"
                  Padding="12"
                  Margin="0,0,0,8">
            <TextBlock Text="Noch kein Material erfasst." Foreground="#6E6E73" />
          </Border>

          <ItemsControl ItemsSource="{Binding Materials}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="Card" Margin="0,0,0,8" Padding="12">
                  <Grid ColumnDefinitions="78,78,*,132,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Text="Menge" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Einheit" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Column="2" Text="Bezeichnung" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Column="3" Text="Status" Foreground="#86868B" FontSize="11" />
                    <NumericUpDown Grid.Row="1" Value="{Binding Quantity}" Minimum="0" Increment="1" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Unit}" />
                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Name}" PlaceholderText="Material" />
                    <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding $parent[Window].DataContext.MaterialStatusOptions}" SelectedItem="{Binding Status}" />
                    <Button Grid.Row="1" Grid.Column="4" Content="×" Click="DeleteMaterial_OnClick" Tag="{Binding}" />
                    <TextBlock Grid.Row="2" Text="Lieferant" Foreground="#86868B" FontSize="11" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Notiz" Foreground="#86868B" FontSize="11" />
                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Supplier}" PlaceholderText="Lieferant" />
                    <TextBox Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="3" Text="{Binding Note}" PlaceholderText="Notiz" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Border Classes="Card"
                  IsVisible="{Binding HasSelectedAttachment}"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="SectionTitle" Text="Vorschau" Margin="0" VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Classes="PreviewClose"
                        Content="×"
                        Click="ClosePreview_OnClick" />
              </Grid>

              <Border MinHeight="220"
                      MaxHeight="520"
                      CornerRadius="12"
                      Background="#F6F7F9"
                      BorderBrush="#E0E0E5"
                      BorderThickness="1"
                      ClipToBounds="True">
                <Grid>
                  <Image IsVisible="{Binding HasPreviewImage}"
                         Source="{Binding PreviewImagePath, Converter={StaticResource ThumbnailImageConverter}}"
                         Stretch="Uniform"
                         MaxWidth="420"
                         MaxHeight="520"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                  <TextBlock IsVisible="{Binding HasPreviewPlaceholder}"
                             Text="{Binding SelectedAttachment.FileTypeBadge}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="28"
                             FontWeight="SemiBold"
                             Foreground="#6E6E73" />
                </Grid>
              </Border>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedAttachment.FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedAttachment.FileTypeBadge}" Foreground="#6E6E73" FontSize="12" Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Extern öffnen" Click="OpenSelectedAttachmentExternal_OnClick" />
              </Grid>

              <Border Background="#F7F8FA"
                      BorderBrush="#E5E5EA"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="iPad-Bearbeitung"
                             FontWeight="SemiBold"
                             Foreground="#525257" />
                  <TextBlock Text="Beim Übernehmen wird diese Anlage aktualisiert. Die alte Version wird gesichert."
                             Foreground="#6E6E73"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <WrapPanel Orientation="Horizontal">
                    <Button Content="Für iPad bereitstellen"
                            Click="ExportAttachmentForIpad_OnClick"
                            Margin="0,0,8,8" />
                    <Button Content="Änderungen prüfen"
                            Click="CheckIpadChanges_OnClick"
                            Margin="0,0,8,8" />
                    <Button Content="Bearbeitung übernehmen"
                            Classes="Primary"
                            IsVisible="{Binding CanImportAttachmentEdit}"
                            Click="ImportIpadChanges_OnClick"
                            Margin="0,0,0,8" />
                  </WrapPanel>
                  <TextBlock Text="{Binding AttachmentEditStatus}"
                             IsVisible="{Binding HasAttachmentEditStatus}"
                             Foreground="#38383D"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Classes="SectionTitle" Text="Anhänge" Margin="0" />
            <Button Grid.Column="1" Content="Datei hinzufügen" Click="AddAttachment_OnClick" />
          </Grid>

          <ItemsControl ItemsSource="{Binding Attachments}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="Card"
                        Margin="0,0,0,8"
                        Padding="12"
                        Background="{Binding CardBackground}"
                        BorderBrush="{Binding CardBorderBrush}"
                        PointerPressed="AttachmentCard_OnPointerPressed">
                  <Grid ColumnDefinitions="170,*,Auto" ColumnSpacing="12">
                    <Border Width="160" Height="110" CornerRadius="10" Background="#F2F3F5" ClipToBounds="True">
                      <Grid>
                        <Image IsVisible="{Binding HasThumbnail}"
                               Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailImageConverter}}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                        <TextBlock IsVisible="{Binding HasNoThumbnail}"
                                   Text="{Binding FileTypeBadge}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#6E6E73" />
                      </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding FileTypeBadge}" Foreground="#6E6E73" FontSize="12" Margin="0,4,0,0" />
                      <TextBlock Text="{Binding StoredPath}" Foreground="#86868B" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="8">
                      <Button Content="Öffnen" Click="OpenAttachment_OnClick" Tag="{Binding}" />
                      <Button Content="Entfernen" Click="DeleteAttachment_OnClick" Tag="{Binding}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
